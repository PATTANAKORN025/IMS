TZ=Asia/Bangkok

# ── TimescaleDB ──────────────────────────────────────────────
POSTGRES_DB=ims
POSTGRES_USER=ims_admin
POSTGRES_PASSWORD=change-me-please

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-please
GRAFANA_ROOT_URL=http://localhost:3000

# ── Alertmanager ─────────────────────────────────────────────
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093

# ── Alert Webhook (Line Notify / Slack / Custom) ─────────────
ALERT_WEBHOOK_URL=https://notify-api.line.me/api/notify
ALERT_WEBHOOK_TOKEN=your-line-notify-token-here

# ── SNMP Community ──────────────────────────────────────────
SNMP_COMMUNITY=Netk@

# ── Node-RED ────────────────────────────────────────────────
# REQUIRED (compose fails if unset). Encrypts stored flow credentials.
NODE_RED_CREDENTIAL_SECRET=change-me-please
# Editor / admin-API login. adminAuth activates only when the bcrypt hash is set.
# Generate it:  docker run -it --rm nodered/node-red:4.0.5-22-minimal npx node-red-admin hash-pw
NODE_RED_ADMIN_USER=admin
NODE_RED_ADMIN_PASSWORD_HASH=
