# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# IMS Git Ignore
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Secrets (NEVER commit)
secrets/
.env
*.key
*.pem

# Docker named-volume / local data dirs
*_data/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temp scripts (auto-generated)
_tmp_*.js
_tmp_*.sql

# K6 results
tests/k6/*-results.json

# node_modules everywhere
**/node_modules/

# ── MiMoCode workspace ────────────────────────────────────
# mimocode.json contains MCP secrets (GitHub PAT). Never commit.
.mimocode/mimocode.json

# ── Node-RED data dir ─────────────────────────────────────
# nodered_data/ holds runtime state (flows.json, .config*, .npm cache) AND the
# hand-maintained config (settings.js, package.json). Ignore the runtime,
# version-control the config. (`!nodered_data/` re-includes the dir so the
# per-file negations below can take effect despite the `*_data/` rule above.)
!nodered_data/
nodered_data/*
!nodered_data/settings.js
!nodered_data/package.json
