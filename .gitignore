# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# IMS Git Ignore
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Secrets (NEVER commit)
secrets/
.env
*.key
*.pem

# Docker named-volume / local data dirs
*_data/

# AI tooling / test artifacts — not project source
.mimocode/
.playwright-mcp/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temp scripts (auto-generated)
_tmp_*.js
_tmp_*.sql

# K6 results
tests/k6/*-results.json

# node_modules everywhere
**/node_modules/

# ── Node-RED data dir ─────────────────────────────────────
!nodered_data/
nodered_data/*
!nodered_data/settings.js
!nodered_data/package.json

# Backups (created by scripts/backup-db.sh)
backups/

# Workspace artifacts (AI tooling, not project source)
ABOUT-ME.md
ARCHIVES/
CONTEXT.md
GLOBAL-INSTRUCTIONS.md
INPUTS/
OUTPUTS/
PROJECT-README.md
SKILLS/
START.md
TASKS.md
TEMPLATES/
dashboard.html
memory/
backup_*.sql
