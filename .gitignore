# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# IMS Git Ignore
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Secrets (NEVER commit)
secrets/
.env
*.key
*.pem

# Docker volumes (local data)
*_data/
nodered_data/

# Node-RED runtime (catch-all)
nodered_data/**

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temp scripts (auto-generated)
_tmp_*.js
_tmp_*.sql

# K6 results
tests/k6/*-results.json

# Docker data volumes (catch-all)
*_data/
**/node_modules/
