# ============================================================
# LDI PRIVATE MIB — Enterprise .1.3.6.1.4.1.9999
# Manufacturing Machine Telemetry (Dynamic Mock Data)
# Rate tuned for realistic 10s polling (slow oscillation)
# ============================================================

# 1. Throughput (20-180 side/hr, slow sine wave ~30s cycle)
1.3.6.1.4.1.9999.1.1.0|2:numeric|min=50,max=200,rate=1

# 2. LDI Temperature (22.1 - 22.7 °C, scaled x100, slow drift)
1.3.6.1.4.1.9999.1.2.0|2:numeric|min=2210,max=2270,rate=1

# 3. LDI Humidity (53% - 60%, scaled x100, slow drift)
1.3.6.1.4.1.9999.1.3.0|2:numeric|min=5300,max=6000,rate=1

# 4. Position Error (PE2: -15.0 to -7.0 µm, PE5: +7.0 to +18.0 µm, scaled x100)
1.3.6.1.4.1.9999.1.4.2|2:numeric|min=-1500,max=-700,rate=2
1.3.6.1.4.1.9999.1.4.5|2:numeric|min=700,max=1800,rate=2

# 5. Judgment Error (4.0 - 16.0 µm, scaled x100)
1.3.6.1.4.1.9999.1.5.1|2:numeric|min=400,max=1600,rate=2

# 6. Power Consumption (1200-3500W, slow drift)
1.3.6.1.4.1.9999.1.6.1|2:numeric|min=1200,max=3500,rate=2

# 7. Vibration (0.5-12.0 mm/s, scaled x100, slow drift)
1.3.6.1.4.1.9999.1.7.1|2:numeric|min=50,max=1200,rate=2

# ============================================================
# WiFi SIGNAL QUALITY — Enterprise .1.3.6.1.4.1.9999.2.x
# RSSI: -85 to -40 dBm (stronger = closer to 0)
# SNR: 10-40 dB (>25 = excellent, <15 = poor)
# ============================================================

