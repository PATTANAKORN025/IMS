{
  "dashboard": {
    "id": 1,
    "uid": "ims-servers",
    "title": "IMS Server Monitoring",
    "tags": ["snmp", "monitoring"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "CPU Load %",
        "type": "timeseries",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 90 }
              ]
            },
            "custom": {
              "fillOpacity": 15,
              "lineWidth": 2,
              "spanNulls": true,
              "gradientMode": "scheme",
              "thresholdsStyle": { "mode": "line+area" }
            }
          }
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
        },
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time_bucket('1 minute', \"time\") AS \"time\", machine_id AS metric, AVG(cpu_load_percent) AS \"CPU Load %\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\") GROUP BY 1, 2 ORDER BY 1;"
        }]
      },
      {
        "id": 2,
        "title": "RAM Usage MB",
        "type": "timeseries",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "unit": "decbytes",
            "min": 0,
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2,
              "spanNulls": true,
              "gradientMode": "scheme"
            }
          }
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
        },
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time_bucket('1 minute', \"time\") AS \"time\", machine_id AS metric, AVG(ram_used_mb) AS \"RAM Used (MB)\", AVG(ram_total_mb) AS \"RAM Total (MB)\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\") GROUP BY 1, 2 ORDER BY 1;"
        }]
      },
      {
        "id": 3,
        "title": "Disk Usage GB",
        "type": "timeseries",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "fieldConfig": {
          "defaults": {
            "unit": "decbytes",
            "min": 0,
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2,
              "spanNulls": true,
              "gradientMode": "scheme"
            }
          }
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
        },
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time_bucket('1 minute', \"time\") AS \"time\", machine_id AS metric, AVG(disk_used_gb) AS \"Disk Used (GB)\", AVG(disk_total_gb) AS \"Disk Total (GB)\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\") GROUP BY 1, 2 ORDER BY 1;"
        }]
      },
      {
        "id": 4,
        "title": "Data Points",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
        "fieldConfig": {
          "defaults": {
            "thresholds": { "steps": [{ "color": "blue", "value": null }] },
            "unit": "short"
          }
        },
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS \"Total Rows\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\");"
        }]
      }
    ]
  },
  "overwrite": true
}
