{
  "dashboard": {
    "id": 1,
    "uid": "ims-servers",
    "title": "IMS Server Monitoring",
    "tags": ["snmp", "monitoring"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 10,
        "title": "CPU Overview",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 90 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto",
          "textMode": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "targets": [{
          "refId": "A",
          "rawSql": "SELECT AVG(cpu_load_percent) AS \"CPU Avg\" FROM public.machine_telemetry WHERE $__timeFilter(time) AND machine_id = 'ERP-MASTER-UBUNTU'"
        }]
      },
      {
        "id": 11,
        "title": "RAM Overview",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10000 },
                { "color": "red", "value": 13000 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "targets": [{
          "refId": "A",
          "rawSql": "SELECT ram_used_mb AS \"RAM Used\" FROM public.machine_telemetry WHERE $__timeFilter(time) AND machine_id = 'ERP-MASTER-UBUNTU' ORDER BY time DESC LIMIT 1"
        }]
      },
      {
        "id": 12,
        "title": "CPU Overview (Windows)",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 90 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "targets": [{
          "refId": "A",
          "rawSql": "SELECT AVG(cpu_load_percent) AS \"CPU Avg\" FROM public.machine_telemetry WHERE $__timeFilter(time) AND machine_id = 'ERP-MASTER-WINDOWS'"
        }]
      },
      {
        "id": 13,
        "title": "RAM Overview (Windows)",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10000 },
                { "color": "red", "value": 13000 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "targets": [{
          "refId": "A",
          "rawSql": "SELECT ram_used_mb AS \"RAM Used\" FROM public.machine_telemetry WHERE $__timeFilter(time) AND machine_id = 'ERP-MASTER-WINDOWS' ORDER BY time DESC LIMIT 1"
        }]
      },
      {
        "id": 14,
        "title": "Disk Overview",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 80000 },
                { "color": "red", "value": 100000 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "targets": [{
          "refId": "A",
          "rawSql": "SELECT disk_used_gb * 1024 AS \"Disk Used\" FROM public.machine_telemetry WHERE $__timeFilter(time) AND machine_id = 'ERP-MASTER-UBUNTU' ORDER BY time DESC LIMIT 1"
        }]
      },
      {
        "id": 15,
        "title": "Disk Overview (Windows)",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 80000 },
                { "color": "red", "value": 100000 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "targets": [{
          "refId": "A",
          "rawSql": "SELECT disk_used_gb * 1024 AS \"Disk Used\" FROM public.machine_telemetry WHERE $__timeFilter(time) AND machine_id = 'ERP-MASTER-WINDOWS' ORDER BY time DESC LIMIT 1"
        }]
      },
      {
        "id": 1,
        "title": "CPU Load %",
        "type": "timeseries",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2,
              "spanNulls": true,
              "lineInterpolation": "smooth",
              "gradientMode": "scheme",
              "thresholdsStyle": {
                "mode": "line+area"
              }
            },
            "max": 100, "min": 0, "unit": "percent",
            "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] }
          },
          "overrides": []
        },
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          },
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["mean", "max"]
          }
        },
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(\"time\", $__interval), machine_id AS metric, AVG(cpu_load_percent) AS \"CPU Load %\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\") GROUP BY 1, 2 ORDER BY 1;"
        }]
      },
      {
        "id": 2,
        "title": "RAM Usage MB",
        "type": "timeseries",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 30,
              "lineWidth": 2,
              "spanNulls": true,
              "stacking": { "mode": "normal" },
              "lineInterpolation": "smooth",
              "gradientMode": "scheme",
              "thresholdsStyle": {
                "mode": "line+area"
              }
            },
            "unit": "decmbytes",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10000 },
                { "color": "red", "value": 13000 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          },
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["mean", "max"]
          }
        },
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(\"time\", $__interval), machine_id AS metric, AVG(ram_used_mb) AS \"RAM Used (MB)\", AVG(ram_total_mb) AS \"RAM Total (MB)\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\") GROUP BY 1, 2 ORDER BY 1;"
        }]
      },
      {
        "id": 3,
        "title": "Disk Usage GB",
        "type": "timeseries",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 30,
              "lineWidth": 2,
              "spanNulls": true,
              "stacking": { "mode": "normal" },
              "lineInterpolation": "smooth",
              "gradientMode": "scheme",
              "thresholdsStyle": {
                "mode": "line+area"
              }
            },
            "unit": "decgbytes",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 80000 },
                { "color": "red", "value": 100000 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          },
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["mean", "max"]
          }
        },
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(\"time\", $__interval), machine_id AS metric, AVG(disk_used_gb) AS \"Disk Used (GB)\", AVG(disk_total_gb) AS \"Disk Total (GB)\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\") GROUP BY 1, 2 ORDER BY 1;"
        }]
      },
      {
        "id": 4,
        "title": "CPU Cores",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
        "fieldConfig": {
          "defaults": {
            "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 32 }] }
          },
          "overrides": []
        },
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT DISTINCT cpu_cores AS \"Cores\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\") ORDER BY 1;"
        }]
      },
      {
        "id": 5,
        "title": "Data Points",
        "type": "stat",
        "datasource": { "uid": "timescaledb" },
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
        "fieldConfig": {
          "defaults": {
            "thresholds": { "steps": [{ "color": "blue", "value": null }] },
            "unit": "short"
          },
          "overrides": []
        },
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS \"Total Rows\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\");"
        }]
      }
    ]
  },
  "overwrite": true
}
