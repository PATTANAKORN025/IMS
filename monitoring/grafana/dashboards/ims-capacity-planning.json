          {
            "matcher": {
              "id": "byName",
              "options": "ERP-MASTER-WINDOWS"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#4ECDC4",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }}",
          "rawSql": "WITH stats AS (SELECT bucket, machine_id, avg_cpu_load, AVG(avg_cpu_load) OVER w AS mu, COALESCE(NULLIF(STDDEV(avg_cpu_load) OVER w, 0), 1) AS sigma FROM public.telemetry_minute_summary WHERE machine_id IN (${machine_id:sqlstring}) AND $__timeFilter(bucket) WINDOW w AS (PARTITION BY machine_id ORDER BY bucket ROWS BETWEEN 60 PRECEDING AND 1 PRECEDING)) SELECT bucket AS time, machine_id AS metric, ROUND(((avg_cpu_load - mu) / sigma)::NUMERIC, 2) AS \"Z-Score\" FROM stats ORDER BY 1",
          "format": "time_series",
          "maxDataPoints": 300
        }
      ],
      "description": "Fleet-wide CPU Z-Score anomaly detection using 60-minute rolling window. Red zones = ±3σ anomalies."
    },
    {
      "id": 602,
      "title": "Temperature Z-Score Anomaly (3σ)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": 60000,
            "thresholdsStyle": {
              "mode": "dashed"
            },
            "gradientMode": "scheme"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": -3
              },
              {
                "color": "transparent",
                "value": -2
              },
              {
                "color": "green",
                "value": -1
              },
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "transparent",
                "value": 2
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ERP-MASTER-UBUNTU"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF6B35",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ERP-MASTER-WINDOWS"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#4ECDC4",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }}",
          "rawSql": "WITH stats AS (SELECT bucket, machine_id, max_temp, AVG(max_temp) OVER w AS mu, COALESCE(NULLIF(STDDEV(max_temp) OVER w, 0), 1) AS sigma FROM public.telemetry_minute_summary WHERE machine_id IN (${machine_id:sqlstring}) AND max_temp > 0 AND $__timeFilter(bucket) WINDOW w AS (PARTITION BY machine_id ORDER BY bucket ROWS BETWEEN 60 PRECEDING AND 1 PRECEDING)) SELECT bucket AS time, machine_id AS metric, ROUND(((max_temp - mu) / sigma)::NUMERIC, 2) AS \"Z-Score\" FROM stats ORDER BY 1",
          "format": "time_series",
          "maxDataPoints": 300
        }
      ],
      "description": "Fleet-wide temperature Z-Score anomaly detection. Red zones indicate readings beyond ±3 standard deviations."
    }
  ],
  "graphTooltip": 1
}