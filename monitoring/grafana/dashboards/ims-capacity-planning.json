                    "rawSql": "WITH daily_disk AS (SELECT time_bucket('1 day', \"time\") AS day, machine_id, AVG(disk_used_gb) AS avg_used FROM public.machine_telemetry WHERE \"time\" > NOW() - INTERVAL '30 days' GROUP BY 1, 2), regression AS (SELECT machine_id, regr_slope(avg_used, EXTRACT(EPOCH FROM day)) AS slope, regr_intercept(avg_used, EXTRACT(EPOCH FROM day)) AS intercept, (SELECT AVG(disk_total_gb) FROM public.machine_telemetry WHERE machine_id = d.machine_id) AS total_gb FROM daily_disk d GROUP BY machine_id) SELECT NOW() + (generate_series(0, 90) || ' days')::INTERVAL AS \"time\", machine_id AS metric, CASE WHEN slope > 0 THEN GREATEST(0, (total_gb - intercept) / slope / 86400 - EXTRACT(EPOCH FROM (NOW() - (NOW() - INTERVAL '30 days'))) / 86400) ELSE 9999 END AS \"Days Until Full\" FROM regression WHERE slope > 0 ORDER BY 1"
                }
            ]
        },
