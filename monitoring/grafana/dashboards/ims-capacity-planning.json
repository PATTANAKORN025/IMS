    {
      "id": 1,
      "title": "Disk: Days Until Full",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 180
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "9999": {
                  "text": "∞",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH daily_usage AS (\n  SELECT machine_id, time_bucket('1 day', hour_bucket) AS day,\n    AVG(avg_disk_used) AS avg_used\n  FROM public.telemetry_hourly_summary\n  WHERE hour_bucket > NOW() - INTERVAL '30 days'\n  GROUP BY 1, 2\n), totals AS (\n  SELECT DISTINCT ON (machine_id) machine_id, disk_total_gb\n  FROM public.machine_telemetry\n  WHERE disk_total_gb > 0\n  ORDER BY machine_id, time DESC\n), regression AS (\n  SELECT machine_id,\n    COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)), 0) AS slope,\n    COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)), 0) AS intercept\n  FROM daily_usage GROUP BY machine_id\n) SELECT machine_id AS metric,\n  CASE WHEN slope <= 0 THEN 9999\n    WHEN t.disk_total_gb <= 0 THEN 9999\n    ELSE GREATEST(0, (t.disk_total_gb - intercept) / slope - EXTRACT(EPOCH FROM NOW()) / 86400)\n  END AS value\nFROM regression r JOIN totals t ON t.machine_id = r.machine_id\nORDER BY value ASC LIMIT 1",
          "format": "table"
        }
      ],
      "description": "Days until disk saturation based on 30-day linear regression. Red < 30d, Orange < 90d, Green > 180d."
    },
