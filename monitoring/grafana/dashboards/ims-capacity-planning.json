      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{ machine_id }} — Used",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('1 hour', hour_bucket) AS \"time\", machine_id, AVG(avg_disk_used) AS \"Disk Used (GB)\" FROM public.telemetry_hourly_summary WHERE $__timeFilter(hour_bucket) AND machine_id IN (${machine_id:sqlstring}) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "B",
          "legendFormat": "{{ machine_id }} — Total",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, disk_total_gb AS \"Disk Total (GB)\" FROM public.machine_telemetry WHERE $__timeFilter(time) AND machine_id IN (${machine_id:sqlstring}) AND disk_total_gb > 0 ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "C",
          "legendFormat": "Forecast — {{ machine_id }}",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH daily AS (SELECT machine_id, time_bucket('1 day', hour_bucket) AS day, AVG(avg_disk_used) AS used FROM public.telemetry_hourly_summary WHERE hour_bucket > NOW() - INTERVAL '30 days' AND machine_id IN (${machine_id:sqlstring}) GROUP BY 1, 2), reg AS (SELECT machine_id, COALESCE(regr_slope(used, EXTRACT(EPOCH FROM day)), 0) AS slope, COALESCE(regr_intercept(used, EXTRACT(EPOCH FROM day)), 0) AS intercept FROM daily GROUP BY machine_id) SELECT generate_series AS time, r.machine_id, GREATEST(0, r.slope * EXTRACT(EPOCH FROM generate_series) + r.intercept) AS \"Forecast (GB)\" FROM reg r, generate_series(NOW(), NOW() + INTERVAL '30 days', INTERVAL '1 day') WHERE r.slope > 0 ORDER BY 1, 2",
          "format": "time_series",
          "maxDataPoints": 300
        }
      ],
      "description": "Hourly disk usage trend with linear regression forecast (dashed orange, 30-day projection)."
