                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?!.*Forecast|Total).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
