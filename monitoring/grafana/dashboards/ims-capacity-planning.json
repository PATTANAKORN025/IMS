            "targets": [
                {
                    "refId": "A",
                    "format": "table",
                    "rawSql": "WITH daily_usage AS (SELECT machine_id, time_bucket('1 day', \"time\") AS day, AVG(ram_used_mb) AS avg_used FROM public.machine_telemetry WHERE \"time\" > NOW() - INTERVAL '30 days' GROUP BY 1, 2), regression AS (SELECT machine_id, COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)), 0) AS slope, COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)), 0) AS intercept FROM daily_usage GROUP BY machine_id) SELECT machine_id AS metric, CASE WHEN slope <= 0 THEN 9999 WHEN (SELECT AVG(ram_total_mb) FROM public.machine_telemetry WHERE machine_id = r.machine_id) <= 0 THEN 9999 ELSE GREATEST(0, ((SELECT AVG(ram_total_mb) FROM public.machine_telemetry WHERE machine_id = r.machine_id) - intercept) / slope - EXTRACT(EPOCH FROM NOW()) / 86400) END AS value FROM regression r ORDER BY value ASC LIMIT 1"
                }
            ]
