    {
      "id": 601,
      "title": "CPU Z-Score Anomaly (3σ)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
