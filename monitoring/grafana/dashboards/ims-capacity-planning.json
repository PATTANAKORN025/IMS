    {
      "id": 10,
      "title": "Disk Usage Trend + Linear Regression Forecast",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "gbytes",
          "min": 0,
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 3,
            "spanNulls": 60000,
            "thresholdsStyle": {
              "mode": "line"
            },
            "gradientMode": "opacity",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Disk Total (GB)"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?!.*Forecast|Total).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#7F00FF"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*UBUNTU.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#00FF87"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*WINDOWS.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#00F2FE"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*(Forecast|Regression|Linear).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#4A5568"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{ machine_id }} — Used",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('1 hour', hour_bucket) AS \"time\", machine_id, AVG(avg_disk_used) AS \"Disk Used (GB)\" FROM public.telemetry_hourly_summary WHERE $__timeFilter(hour_bucket) AND machine_id IN (${machine_id:sqlstring}) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "B",
          "legendFormat": "{{ machine_id }} — Total",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, disk_total_gb AS \"Disk Total (GB)\" FROM public.machine_telemetry WHERE $__timeFilter(time) AND machine_id IN (${machine_id:sqlstring}) AND disk_total_gb > 0 ORDER BY 1",
