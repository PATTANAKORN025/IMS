      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }}",
          "rawSql": "WITH stats AS (SELECT bucket, machine_id, cpu_load_percent, AVG(avg_cpu_load) OVER w AS mu, COALESCE(NULLIF(STDDEV(avg_cpu_load) OVER w, 0), 1) AS sigma FROM public.sys_metrics WHERE machine_id IN (${machine_id:sqlstring}) AND $__timeFilter(bucket) WINDOW w AS (PARTITION BY machine_id ORDER BY bucket ROWS BETWEEN 60 PRECEDING AND 1 PRECEDING)) SELECT time, machine_id AS metric, ROUND(((avg_cpu_load - mu) / sigma)::NUMERIC, 2) AS \"Z-Score\" FROM stats ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
