          "rawSql": "WITH daily_usage AS (\n  SELECT machine_id, time_bucket('1 day', hour_bucket) AS day,\n    AVG(avg_ram_used) AS avg_used\n  FROM public.telemetry_hourly_summary\n  WHERE hour_bucket > NOW() - INTERVAL '30 days'\n  GROUP BY 1, 2\n), totals AS (\n  SELECT DISTINCT ON (machine_id) machine_id, ram_total_mb\n  FROM public.machine_telemetry\n  WHERE ram_total_mb > 0\n  ORDER BY machine_id, time DESC\n), regression AS (\n  SELECT machine_id,\n    COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)), 0) AS slope,\n    COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)), 0) AS intercept\n  FROM daily_usage GROUP BY machine_id\n) SELECT machine_id AS metric,\n  CASE WHEN slope <= 0 THEN 9999\n    WHEN t.ram_total_mb <= 0 THEN 9999\n    ELSE GREATEST(0, (t.ram_total_mb - intercept) / slope - EXTRACT(EPOCH FROM NOW()) / 86400)\n  END AS value\nFROM regression r JOIN totals t ON t.machine_id = r.machine_id\nORDER BY value ASC LIMIT 1",
