    {
      "id": 50,
      "title": "Days Until Full (Cyberpunk Battery)",
      "type": "volkovlabs-echarts-panel",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "transparent": true,
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "code": "const getVal = (idx) => {\n  try {\n    const f = data.series[idx].fields.find(x => x.type === 'number');\n    const v = f.values.buffer || f.values;\n    return v[v.length - 1] || Infinity;\n  } catch(e) { return Infinity; }\n};\nconst disk = getVal(0); const ram = getVal(1); const cpu = getVal(2);\nconst formatVal = (v) => v > 365 ? 365 : (v < 0 ? 0 : v);\nreturn {\n  backgroundColor: 'transparent',\n  grid: { top: '10%', bottom: '5%', left: '15%', right: '15%' },\n  xAxis: { type: 'value', show: false, max: 365 },\n  yAxis: { type: 'category', data: ['CPU', 'RAM', 'DISK'], axisLine: {show: false}, axisTick: {show: false}, axisLabel: {color: '#00F2FE', fontSize: 16, fontFamily: 'Orbitron', fontWeight: 'bold'} },\n  series: [{\n    type: 'bar',\n    data: [\n      { value: formatVal(cpu), itemStyle: { color: '#00FF87', shadowBlur: 15, shadowColor: '#00FF87'} },\n      { value: formatVal(ram), itemStyle: { color: '#00F2FE', shadowBlur: 15, shadowColor: '#00F2FE'} },\n      { value: formatVal(disk), itemStyle: { color: '#7F00FF', shadowBlur: 15, shadowColor: '#7F00FF'} }\n    ],\n    barWidth: 15,\n    itemStyle: { borderRadius: [0, 8, 8, 0] },\n    label: {\n      show: true, position: 'right', color: '#fff', fontSize: 14,\n      formatter: (p) => {\n        const raw = [cpu, ram, disk][p.dataIndex];\n        return raw > 365 ? 'SAFE (\u221e)' : Math.round(raw) + ' Days';\n      }\n    },\n    showBackground: true,\n    backgroundStyle: { color: 'rgba(255, 255, 255, 0.05)', borderRadius: [0, 8, 8, 0] }\n  }]\n};",
        "option": "{}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT 'Disk' AS metric, CASE WHEN r.slope<=0 THEN 9999 ELSE GREATEST(0,(t.disk_total_gb - r.intercept)/r.slope - EXTRACT(EPOCH FROM NOW())/86400) END AS \"Days Until Full\" FROM (SELECT machine_id, COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)),0) AS slope, COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)),0) AS intercept FROM (SELECT machine_id, time_bucket('1 day',hour_bucket) AS day, AVG(avg_disk_used) AS avg_used FROM public.telemetry_hourly_summary WHERE hour_bucket > NOW()-INTERVAL '30 days' GROUP BY 1,2) d GROUP BY machine_id) r JOIN (SELECT DISTINCT ON (machine_id) machine_id, disk_total_gb FROM public.machine_telemetry WHERE disk_total_gb>0 ORDER BY machine_id, time DESC) t ON t.machine_id=r.machine_id ORDER BY value ASC LIMIT 1",
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT 'RAM' AS metric, CASE WHEN r.slope<=0 THEN 9999 ELSE GREATEST(0,(t.ram_total_mb - r.intercept)/r.slope - EXTRACT(EPOCH FROM NOW())/86400) END AS \"Days Until Full\" FROM (SELECT machine_id, COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)),0) AS slope, COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)),0) AS intercept FROM (SELECT machine_id, time_bucket('1 day',hour_bucket) AS day, AVG(avg_ram_used) AS avg_used FROM public.telemetry_hourly_summary WHERE hour_bucket > NOW()-INTERVAL '30 days' GROUP BY 1,2) d GROUP BY machine_id) r JOIN (SELECT DISTINCT ON (machine_id) machine_id, ram_total_mb FROM public.machine_telemetry WHERE ram_total_mb>0 ORDER BY machine_id, time DESC) t ON t.machine_id=r.machine_id ORDER BY value ASC LIMIT 1",
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT 'CPU' AS metric, CASE WHEN slope<=0 THEN 9999 ELSE GREATEST(0,(100-intercept)/slope-EXTRACT(EPOCH FROM NOW())/86400) END AS \"Days Until Full\" FROM (SELECT machine_id, COALESCE(regr_slope(avg_cpu, EXTRACT(EPOCH FROM day)),0) AS slope, COALESCE(regr_intercept(avg_cpu, EXTRACT(EPOCH FROM day)),0) AS intercept FROM (SELECT machine_id, time_bucket('1 day',hour_bucket) AS day, AVG(avg_cpu_load) AS avg_cpu FROM public.telemetry_hourly_summary WHERE hour_bucket > NOW()-INTERVAL '30 days' GROUP BY 1,2) d GROUP BY machine_id) ORDER BY 2 ASC LIMIT 1",
          "format": "table"
        }
      ],
      "description": "Cyberpunk battery gauge: horizontal glowing bars showing days until saturation for CPU, RAM, and Disk."
    },
