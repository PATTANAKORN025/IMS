          "rawSql": "WITH daily_usage AS (  SELECT machine_id, time_bucket('1 day', hour_bucket) AS day,    AVG(avg_ram_used) AS avg_used  FROM public.telemetry_hourly_summary  WHERE hour_bucket > NOW() - INTERVAL '30 days'  GROUP BY 1, 2), totals AS (  SELECT DISTINCT ON (machine_id) machine_id, ram_total_mb  FROM public.machine_telemetry  WHERE ram_total_mb > 0  ORDER BY machine_id, time DESC), regression AS (  SELECT machine_id,    COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)), 0) AS slope,    COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)), 0) AS intercept  FROM daily_usage GROUP BY machine_id) SELECT r.machine_id AS metric,  CASE WHEN r.slope <= 0 THEN 9999    WHEN t.ram_total_mb <= 0 THEN 9999    ELSE GREATEST(0, (t.ram_total_mb - r.intercept) / r.slope - EXTRACT(EPOCH FROM NOW()) / 86400)  END AS value FROM regression r JOIN totals t ON t.machine_id = r.machine_id ORDER BY value ASC LIMIT 1",
