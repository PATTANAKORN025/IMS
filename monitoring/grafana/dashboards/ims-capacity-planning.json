          "legendFormat": "{{ machine_id }}",
          "rawSql": "WITH totals AS (\n  SELECT DISTINCT ON (machine_id) machine_id, ram_total_mb\n  FROM public.machine_telemetry\n  WHERE ram_total_mb > 0\n  ORDER BY machine_id, time DESC\n)\nSELECT h.hour_bucket AS time, h.machine_id,\n  ROUND((h.avg_ram_used / NULLIF(t.ram_total_mb, 0) * 100)::NUMERIC, 1) AS \"Avg RAM %\"\nFROM public.telemetry_hourly_summary h\nJOIN totals t ON t.machine_id = h.machine_id\nWHERE h.hour_bucket > NOW() - INTERVAL '30 days'\n  AND h.machine_id IN (${machine_id:sqlstring})\nORDER BY 1",
