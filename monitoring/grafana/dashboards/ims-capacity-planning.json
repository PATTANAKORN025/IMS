          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": -3
              },
              {
                "color": "transparent",
                "value": -2
              },
              {
                "color": "green",
                "value": -1
              },
              {
                "color": "green",
                "value": 1
              },
