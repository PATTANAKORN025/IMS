                ]
            },
            "targets": [
                {
                    "refId": "A",
                    "format": "table",
                    "rawSql": "WITH latest AS (SELECT machine_id, disk_used_gb, disk_total_gb, ram_used_mb, ram_total_mb, cpu_load_percent, \"time\" FROM public.machine_telemetry WHERE \"time\" > NOW() - INTERVAL '5 minutes' ORDER BY \"time\" DESC), daily_disk AS (SELECT machine_id, regr_slope(disk_used_gb, EXTRACT(EPOCH FROM time_bucket('1 day', \"time\"))) AS slope, regr_intercept(disk_used_gb, EXTRACT(EPOCH FROM time_bucket('1 day', \"time\"))) AS intercept FROM public.machine_telemetry WHERE \"time\" > NOW() - INTERVAL '30 days' GROUP BY machine_id) SELECT l.machine_id AS \"Machine\", ROUND(l.disk_used_gb::NUMERIC, 1) || ' / ' || ROUND(l.disk_total_gb::NUMERIC, 1) || ' GB' AS \"Disk\", ROUND((l.disk_used_gb / NULLIF(l.disk_total_gb, 0) * 100)::NUMERIC, 1) AS \"Current Disk %\", CASE WHEN COALESCE(d.slope, 0) <= 0 THEN 9999 ELSE GREATEST(0, ROUND(((l.disk_total_gb - d.intercept) / d.slope - EXTRACT(EPOCH FROM NOW()) / 86400)::NUMERIC, 0)) END AS \"Disk Days Left\", ROUND((l.ram_used_mb / NULLIF(l.ram_total_mb, 0) * 100)::NUMERIC, 1) AS \"Current RAM %\", 9999 AS \"RAM Days Left\", ROUND(l.cpu_load_percent::NUMERIC, 1) AS \"Current CPU %\", 9999 AS \"CPU Days Left\" FROM latest l LEFT JOIN daily_disk d ON l.machine_id = d.machine_id ORDER BY \"Disk Days Left\" ASC"
                }
            ]
        },
