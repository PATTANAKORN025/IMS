    {
      "id": 50,
      "title": "Days Until Full (Resource Battery)",
      "type": "bargauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "transparent": true,
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "max": 365,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizHeight": 16,
        "minVizWidth": 0,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT 'Disk' AS metric, LEAST(CASE WHEN r.slope<=0 THEN 365 ELSE GREATEST(0,(t.disk_total_gb - r.intercept)/r.slope - EXTRACT(EPOCH FROM NOW())/86400) END, 365) AS \"Days Until Full\" FROM (SELECT machine_id, COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)),0) AS slope, COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)),0) AS intercept FROM (SELECT machine_id, time_bucket('1 day',hour_bucket) AS day, AVG(avg_disk_used) AS avg_used FROM public.telemetry_hourly_summary WHERE hour_bucket > NOW()-INTERVAL '30 days' GROUP BY 1,2) d GROUP BY machine_id) r JOIN (SELECT DISTINCT ON (machine_id) machine_id, disk_total_gb FROM public.machine_telemetry WHERE disk_total_gb>0 ORDER BY machine_id, time DESC) t ON t.machine_id=r.machine_id ORDER BY 1 ASC LIMIT 1",
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT 'RAM' AS metric, LEAST(CASE WHEN r.slope<=0 THEN 365 ELSE GREATEST(0,(t.ram_total_mb - r.intercept)/r.slope - EXTRACT(EPOCH FROM NOW())/86400) END, 365) AS \"Days Until Full\" FROM (SELECT machine_id, COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)),0) AS slope, COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)),0) AS intercept FROM (SELECT machine_id, time_bucket('1 day',hour_bucket) AS day, AVG(avg_ram_used) AS avg_used FROM public.telemetry_hourly_summary WHERE hour_bucket > NOW()-INTERVAL '30 days' GROUP BY 1,2) d GROUP BY machine_id) r JOIN (SELECT DISTINCT ON (machine_id) machine_id, ram_total_mb FROM public.machine_telemetry WHERE ram_total_mb>0 ORDER BY machine_id, time DESC) t ON t.machine_id=r.machine_id ORDER BY 1 ASC LIMIT 1",
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT 'CPU' AS metric, LEAST(CASE WHEN slope<=0 THEN 365 ELSE GREATEST(0,(100-intercept)/slope-EXTRACT(EPOCH FROM NOW())/86400) END, 365) AS \"Days Until Full\" FROM (SELECT machine_id, COALESCE(regr_slope(avg_cpu, EXTRACT(EPOCH FROM day)),0) AS slope, COALESCE(regr_intercept(avg_cpu, EXTRACT(EPOCH FROM day)),0) AS intercept FROM (SELECT machine_id, time_bucket('1 day',hour_bucket) AS day, AVG(avg_cpu_load) AS avg_cpu FROM public.telemetry_hourly_summary WHERE hour_bucket > NOW()-INTERVAL '30 days' GROUP BY 1,2) d GROUP BY machine_id) ORDER BY 2 ASC LIMIT 1",
          "format": "table"
        }
      ],
      "description": "Days until resource saturation for CPU, RAM, and Disk using 30-day linear regression."
    },
