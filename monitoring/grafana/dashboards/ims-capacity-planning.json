    {
      "id": 1,
      "title": "Disk: Days Until Full",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 180
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH daily_usage AS (SELECT machine_id, time_bucket('1 day', time) AS day, AVG(disk_used_gb) AS avg_used FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '30 days' GROUP BY 1, 2), regression AS (SELECT machine_id, COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)), 0) AS slope, COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)), 0) AS intercept FROM daily_usage GROUP BY machine_id) SELECT machine_id AS metric, CASE WHEN slope <= 0 THEN 9999 WHEN (SELECT AVG(disk_total_gb) FROM public.machine_telemetry WHERE machine_id = r.machine_id) <= 0 THEN 9999 ELSE GREATEST(0, ((SELECT AVG(disk_total_gb) FROM public.machine_telemetry WHERE machine_id = r.machine_id) - intercept) / slope - EXTRACT(EPOCH FROM NOW()) / 86400) END AS value FROM regression r ORDER BY value ASC LIMIT 1",
          "format": "table"
        }
      ],
      "description": "Days until disk saturation based on 30-day linear regression. Red < 30d, Orange < 90d, Green > 180d."
    },
    {
      "id": 2,
      "title": "RAM: Days Until Full",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 180
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH daily_usage AS (SELECT machine_id, time_bucket('1 day', time) AS day, AVG(ram_used_mb) AS avg_used FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '30 days' GROUP BY 1, 2), regression AS (SELECT machine_id, COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)), 0) AS slope, COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)), 0) AS intercept FROM daily_usage GROUP BY machine_id) SELECT machine_id AS metric, CASE WHEN slope <= 0 THEN 9999 WHEN (SELECT AVG(ram_total_mb) FROM public.machine_telemetry WHERE machine_id = r.machine_id) <= 0 THEN 9999 ELSE GREATEST(0, ((SELECT AVG(ram_total_mb) FROM public.machine_telemetry WHERE machine_id = r.machine_id) - intercept) / slope - EXTRACT(EPOCH FROM NOW()) / 86400) END AS value FROM regression r ORDER BY value ASC LIMIT 1",
          "format": "table"
        }
      ],
      "description": "Days until RAM saturation based on 30-day linear regression trend."
    },
    {
      "id": 3,
      "title": "CPU: Days Until Saturation",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
