                "value": 180
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "9999": {
                  "text": "\u221e",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH daily_usage AS (  SELECT machine_id, time_bucket('1 day', hour_bucket) AS day,    AVG(avg_disk_used) AS avg_used  FROM public.telemetry_hourly_summary  WHERE hour_bucket > NOW() - INTERVAL '30 days'  GROUP BY 1, 2), totals AS (  SELECT DISTINCT ON (machine_id) machine_id, disk_total_gb  FROM public.machine_telemetry  WHERE disk_total_gb > 0  ORDER BY machine_id, time DESC), regression AS (  SELECT machine_id,    COALESCE(regr_slope(avg_used, EXTRACT(EPOCH FROM day)), 0) AS slope,    COALESCE(regr_intercept(avg_used, EXTRACT(EPOCH FROM day)), 0) AS intercept  FROM daily_usage GROUP BY machine_id) SELECT r.machine_id AS metric,  CASE WHEN r.slope <= 0 THEN 9999    WHEN t.disk_total_gb <= 0 THEN 9999    ELSE GREATEST(0, (t.disk_total_gb - r.intercept) / r.slope - EXTRACT(EPOCH FROM NOW()) / 86400)  END AS value FROM regression r JOIN totals t ON t.machine_id = r.machine_id ORDER BY value ASC LIMIT 1",
          "format": "table"
        }
      ],
      "description": "Days until disk saturation based on 30-day linear regression. Red < 30d, Orange < 90d, Green > 180d.",
      "transparent": true,
      "links": [
        {
          "title": "Drill-down \u2192 Engineering",
          "url": "/d/ims-engineering?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ]
    },
