                ]
            },
            "targets": [
                {
                    "refId": "A",
                    "format": "table",
                    "rawSql": "WITH daily_disk AS (SELECT machine_id, regr_slope(disk_used_gb, EXTRACT(EPOCH FROM time_bucket('1 day', \"time\"))) AS slope, regr_intercept(disk_used_gb, EXTRACT(EPOCH FROM time_bucket('1 day', \"time\"))) AS intercept FROM public.machine_telemetry WHERE \"time\" > NOW() - INTERVAL '30 days' GROUP BY machine_id), latest AS (SELECT machine_id, disk_used_gb, disk_total_gb FROM public.machine_telemetry WHERE \"time\" > NOW() - INTERVAL '5 minutes' GROUP BY machine_id, disk_used_gb, disk_total_gb) SELECT l.machine_id AS \"Machine\", ROUND(l.disk_used_gb::NUMERIC, 1) || ' / ' || ROUND(l.disk_total_gb::NUMERIC, 1) || ' GB' AS \"Disk Usage\", CASE WHEN COALESCE(d.slope, 0) <= 0 THEN 9999 ELSE GREATEST(0, ROUND(((l.disk_total_gb - d.intercept) / d.slope - EXTRACT(EPOCH FROM NOW()) / 86400)::NUMERIC, 0)) END AS \"Days Left\" FROM latest l LEFT JOIN daily_disk d ON l.machine_id = d.machine_id WHERE CASE WHEN COALESCE(d.slope, 0) <= 0 THEN 9999 ELSE GREATEST(0, ((l.disk_total_gb - d.intercept) / d.slope - EXTRACT(EPOCH FROM NOW()) / 86400)) END < 14 ORDER BY \"Days Left\" ASC"
                }
            ]
        },
