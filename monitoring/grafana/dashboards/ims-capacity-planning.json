          "rawSql": "SELECT time_bucket('1 hour', hour_bucket) AS \"time\", machine_id, AVG(avg_disk_used) AS \"Disk Used (GB)\" FROM public.telemetry_hourly_summary WHERE $__timeFilter(hour_bucket) AND machine_id IN (${machine_id:sqlstring}) GROUP BY 1, 2 ORDER BY 1",
