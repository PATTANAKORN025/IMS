                    "rawSql": "WITH stats AS (  SELECT machine_id, AVG(cpu_load_percent) AS mu,   COALESCE(NULLIF(STDDEV(cpu_load_percent), 0), 1) AS sigma   FROM public.machine_telemetry   WHERE time > NOW() - INTERVAL '24 hours'   GROUP BY machine_id) SELECT t.\"time\" AS time, t.machine_id AS metric, ROUND(((t.cpu_load_percent - s.mu) / s.sigma)::NUMERIC, 2) AS \"Z-Score\" FROM public.machine_telemetry t JOIN stats s ON t.machine_id = s.machine_id WHERE $__timeFilter(t.\"time\") ORDER BY 1"
