      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{ machine_id }} — Used",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('1 hour', time) AS time, machine_id, AVG(disk_used_gb) AS \"Disk Used (GB)\" FROM public.sys_metrics WHERE $__timeFilter(time) AND machine_id IN (${machine_id:sqlstring}) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "B",
          "legendFormat": "{{ machine_id }} — Total",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('1 hour', time) AS time, machine_id, AVG(disk_total_gb) AS \"Disk Total (GB)\" FROM public.sys_metrics WHERE $__timeFilter(time) AND machine_id IN (${machine_id:sqlstring}) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ]
