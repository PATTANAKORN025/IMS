                    "format": "table",
                    "rawSql": "WITH daily_usage AS (SELECT machine_id, time_bucket('1 day', \"time\") AS day, AVG(cpu_load_percent) AS avg_cpu FROM public.machine_telemetry WHERE \"time\" > NOW() - INTERVAL '30 days' GROUP BY 1, 2), regression AS (SELECT machine_id, COALESCE(regr_slope(avg_cpu, EXTRACT(EPOCH FROM day)), 0) AS slope, COALESCE(regr_intercept(avg_cpu, EXTRACT(EPOCH FROM day)), 0) AS intercept FROM daily_usage GROUP BY machine_id) SELECT machine_id AS metric, CASE WHEN slope <= 0 THEN 9999 ELSE GREATEST(0, (100 - intercept) / slope - EXTRACT(EPOCH FROM NOW()) / 86400) END AS value FROM regression r ORDER BY value ASC LIMIT 1"
                }
