      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": 60000,
            "thresholdsStyle": {
