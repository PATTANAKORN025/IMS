      "options": {
        "mode": "html",
        "content": "<style>\n@import url(\"https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap\");\n.dashboard-page { background: #050505 !important; font-family: \"Rajdhani\", sans-serif !important; }\n.panel-container {\n  position: relative;\n  background: linear-gradient(145deg, rgba(16,20,30,0.7) 0%, rgba(5,7,12,0.9) 100%) !important;\n  border-top: 1px solid rgba(0,242,254,0.6) !important;\n  border-left: 1px solid rgba(0,242,254,0.3) !important;\n  border-right: 1px solid rgba(0,242,254,0.1) !important;\n  border-bottom: 1px solid rgba(0,242,254,0.1) !important;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.8), inset 0 1px 15px rgba(0,242,254,0.05) !important;\n  backdrop-filter: blur(16px) !important;\n  border-radius: 6px !important;\n  transition: transform 0.3s cubic-bezier(0.175,0.885,0.32,1.275), box-shadow 0.3s ease;\n}\n.panel-container:hover {\n  transform: translateY(-5px) scale(1.02);\n  box-shadow: 0 15px 40px rgba(0,242,254,0.2), inset 0 1px 15px rgba(0,242,254,0.1) !important;\n  z-index: 100;\n}\n@keyframes scanline {\n  0% { transform: translateY(-100%); }\n  100% { transform: translateY(1000%); }\n}\n.panel-container::after {\n  content: \"\"; position: absolute; top: 0; left: 0; right: 0; height: 10px;\n  background: linear-gradient(to bottom, transparent, #00F2FE, transparent);\n  animation: scanline 4s linear infinite; pointer-events: none;\n  will-change: transform; border-radius: inherit;\n}\n.panel-title { color: #A0AEC0 !important; font-size: 13px !important; text-transform: uppercase; }\n</style>\n<div style=\"height:100%;display:flex;align-items:center;gap:16px;padding:0 20px;background:#0D1117;border-bottom:2px solid #1F2937;\"><span style=\"font-size:28px;font-weight:700;color:#E5E7EB;letter-spacing:4px;font-family:Rajdhani,sans-serif;white-space:nowrap;text-shadow:0 0 15px rgba(0,242,254,0.3);\">APEX <span style=\"color:#00F2FE\">COMMAND</span></span><div style=\"flex:1\"></div><a href=\"/d/ims-noc-overview\" target=\"_blank\" style=\"padding:6px 16px;font-size:13px;font-weight:700;letter-spacing:1px;text-decoration:none;color:#6B7280;border-bottom:2px solid transparent;transition:all 0.3s;\" onmouseover=\"this.style.color='#E5E7EB';this.style.borderBottomColor='#374151'\" onmouseout=\"this.style.color='#6B7280';this.style.borderBottomColor='transparent'\">NOC</a><a href=\"/d/ims-engineering\" target=\"_blank\" style=\"padding:6px 16px;font-size:13px;font-weight:700;letter-spacing:1px;text-decoration:none;color:#6B7280;border-bottom:2px solid transparent;transition:all 0.3s;\" onmouseover=\"this.style.color='#E5E7EB';this.style.borderBottomColor='#374151'\" onmouseout=\"this.style.color='#6B7280';this.style.borderBottomColor='transparent'\">ENG</a><a href=\"/d/ims-capacity\" target=\"_blank\" style=\"padding:6px 16px;font-size:13px;font-weight:700;letter-spacing:1px;text-decoration:none;color:#7F00FF;border-bottom:2px solid #7F00FF;background:#0D1117;\">CAP</a></div>"
