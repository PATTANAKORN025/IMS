            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Temp (°C)"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 45
                    },
                    {
                      "color": "red",
                      "value": 55
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Status",
            "desc": false
          }
        ],
        "rowHeight": 0.4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT machine_id AS \"Server Name\", CASE WHEN MAX(time) > NOW() - INTERVAL '2 minutes' THEN 'online' WHEN MAX(time) > NOW() - INTERVAL '10 minutes' THEN 'stale' ELSE 'offline' END AS \"Status\", ROUND(AVG(cpu_load_percent)::NUMERIC, 1) AS \"CPU (%)\", ROUND(AVG(temp_c)::NUMERIC, 0) AS \"Temp (°C)\", COUNT(*)::TEXT AS \"Machines\" FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '10 minutes' GROUP BY machine_id ORDER BY machine_id",
          "format": "table"
        }
      ],
      "links": [
        {
          "title": "Drill-down → Engineering: ${__data.fields[\"Server Name\"]}",
          "url": "/d/ims-engineering?var-machine_id=${__data.fields[\"Server Name\"]}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Real-time fleet status table showing each machine's CPU, RAM, disk, temperature, network, and LDI health. Click machine name to drill down.",
      "transparent": true
