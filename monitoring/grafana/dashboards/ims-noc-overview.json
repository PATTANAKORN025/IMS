{
  "uid": "ims-noc-overview",
  "title": "IMS NOC Overview",
  "tags": [
    "ims",
    "noc"
  ],
  "timezone": "Asia/Bangkok",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "links": [
    {
      "title": "TV Kiosk Mode",
      "url": "/d/ims-noc-overview?orgId=1&kiosk=tv",
      "type": "link",
      "icon": "bolt",
      "targetBlank": true
    },
    {
      "title": "Engineering Drill-Down",
      "url": "/d/ims-engineering",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    },
    {
      "title": "AIOps & Capacity",
      "url": "/d/ims-capacity",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT machine_id FROM public.machine_telemetry ORDER BY machine_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Machine"
      },
      {
        "name": "interface",
        "type": "query",
        "query": "SELECT DISTINCT key FROM (SELECT interface_metrics FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '10 minutes' ORDER BY time DESC LIMIT 100) AS recent, jsonb_object_keys(recent.interface_metrics) AS key ORDER BY key",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Interface"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 999,
      "type": "grafana-clock-panel",
      "title": "",
      "datasource": null,
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "clock",
        "clockType": "24hour",
        "pendulum": false,
        "showDate": true,
        "dateSettings": {
          "dateFormat": "YYYY-MM-DD",
          "locale": "en",
          "timeZone": "Asia/Bangkok"
        },
        "timeSettings": {
          "showSeconds": true,
          "showHour": true,
          "showMinutes": true,
          "timeFormat": "24"
        },
        "timezone": "Asia/Bangkok",
        "bgColor": "transparent"
      },
      "description": "Current time and date (Asia/Bangkok timezone)."
    },
    {
      "id": 998,
      "type": "alertlist",
      "title": "Active Alerts",
      "description": "Currently firing alerts from Grafana unified alerting.",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "showOptions": "current",
        "sortOrder": 1,
        "stateFilter": {
          "firing": true,
          "pending": false,
          "noData": false,
          "normal": false,
          "error": false
        },
        "alertName": "",
        "dashboardAlerts": false,
        "folder": null
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "FLEET OVERVIEW",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "collapsed": false
    },
    {
      "id": 901,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"text-align:center;padding:2px 0;\"><hr style=\"border:none;border-top:1px solid #00F2FE;opacity:0.25;margin:0;\"/></div>"
      },
      "datasource": null,
      "description": "Visual section divider."
    },
    {
      "id": 2,
      "title": "Machines Online",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background-solid",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT COUNT(DISTINCT machine_id) AS value FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '5 minutes'",
          "format": "table"
        }
      ],
      "description": "Number of machines reporting telemetry within the last 5 minutes."
    },
    {
      "id": 4,
      "title": "Fleet Health Score",
      "type": "volkovlabs-echarts-panel",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "code": "let score = 0;\nif (data.series.length > 0 && data.series[0].fields.length > 0) {\n  const field = data.series[0].fields.find(f => f.name === 'value' || f.name === 'health_score');\n  if (field && field.values.length > 0) score = field.values[0];\n}\nreturn {\n  backgroundColor: 'transparent',\n  series: [{\n    type: 'gauge',\n    startAngle: 180, endAngle: 0,\n    min: 0, max: 100,\n    pointer: { show: false },\n    progress: {\n      show: true, overlap: false, roundCap: true, clip: false,\n      itemStyle: {\n        color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [\n          { offset: 0, color: '#FF003C' },\n          { offset: 0.5, color: '#FF9100' },\n          { offset: 1, color: '#00FF87' }\n        ]),\n        shadowBlur: 15, shadowColor: 'rgba(0, 255, 135, 0.6)'\n      }\n    },\n    axisLine: { lineStyle: { width: 15, color: [[1, 'rgba(255,255,255,0.05)']] } },\n    detail: { fontSize: 40, color: '#fff', textShadowBlur: 10, textShadowColor: '#00FF87', formatter: '{value}%' },\n    data: [{ value: score, name: 'FLEET HEALTH' }],\n    title: { color: '#00F2FE', fontSize: 12, offsetCenter: ['0%', '30%'] }\n  }]\n};",
        "option": "{}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT 'Fleet Score' AS metric, value FROM public.v_fleet_score",
          "format": "table"
        }
      ],
      "description": "Composite fleet health score (0-100%) from v_fleet_health view."
    },
    {
      "id": 601,
      "title": "LDI Yield Risk (% Outside Tolerance)",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background-solid",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH ldi AS (SELECT machine_id, ldi_pe, ldi_je FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '1 hour' AND ldi_pe IS NOT NULL) SELECT ROUND(100.0 * SUM(CASE WHEN ABS(ldi_pe) > 10 OR ABS(ldi_je) > 10 THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0)::NUMERIC, 1) AS value FROM ldi",
          "format": "table"
        }
      ],
      "description": "Percentage of LDI readings exceeding \u00b110\u00b5m tolerance in the last hour. Green <5%, Yellow <15%, Red \u226515%."
    },
    {
      "id": 602,
      "title": "Power Cost Estimation (THB/day)",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyTHB",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background-solid",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH power_data AS (SELECT machine_id, AVG(ldi_power) AS avg_watts FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '1 day' AND ldi_power IS NOT NULL GROUP BY machine_id) SELECT 'Fleet Power Cost' AS metric, ROUND(SUM(avg_watts * 24 * 4.5 / 1000)::NUMERIC, 0) AS value FROM power_data",
          "format": "table"
        }
      ],
      "description": "Estimated daily power cost in Thai Baht based on average LDI power consumption \u00d7 24 hours \u00d7 4.5 THB/kWh."
    },
    {
      "id": 200,
      "type": "row",
      "title": "FLEET STATUS TABLE",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Server Fleet Status",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "online": {
                        "color": "green",
                        "text": "online"
                      },
                      "stale": {
                        "color": "yellow",
                        "text": "stale"
                      },
                      "offline": {
                        "color": "red",
                        "text": "offline"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Last Update"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "unit",
                "value": "dateTimeFromNow"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CPU (%)"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 80
                    },
                    {
                      "color": "red",
                      "value": 90
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Temp (\u00b0C)"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 45
                    },
                    {
                      "color": "red",
                      "value": 55
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Status",
            "desc": false
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT machine_id AS \"Server Name\", CASE WHEN MAX(time) > NOW() - INTERVAL '2 minutes' THEN 'online' WHEN MAX(time) > NOW() - INTERVAL '10 minutes' THEN 'stale' ELSE 'offline' END AS \"Status\", ROUND(AVG(cpu_load_percent)::NUMERIC, 1) AS \"CPU (%)\", ROUND(AVG(temp_c)::NUMERIC, 0) AS \"Temp (\u00b0C)\", MAX(time) AS \"Last Update\" FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '10 minutes' GROUP BY machine_id ORDER BY machine_id",
          "format": "table"
        }
      ],
      "links": [
        {
          "title": "Drill-down \u2192 Engineering: ${__data.fields[\"Server Name\"]}",
          "url": "/d/ims-engineering?var-machine_id=${__data.fields[\"Server Name\"]}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Real-time fleet status table showing each machine's CPU, RAM, disk, temperature, network, and LDI health. Click machine name to drill down."
    },
    {
      "id": 900,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "options": {
        "mode": "html",
        "content": "<style>\n  @import url(\"https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap\");\n  .dashboard-page {\n    background: radial-gradient(circle at center, #0a0b10 0%, #000000 100%) !important;\n    font-family: \"Orbitron\", sans-serif !important;\n  }\n  .panel-container {\n    background: rgba(10, 15, 30, 0.6) !important;\n    border: 1px solid rgba(0, 242, 254, 0.2) !important;\n    box-shadow: 0 0 15px rgba(0, 242, 254, 0.05), inset 0 0 20px rgba(0, 242, 254, 0.02) !important;\n    backdrop-filter: blur(10px) !important;\n    border-radius: 8px !important;\n  }\n  .panel-title {\n    font-family: \"Orbitron\", sans-serif !important;\n    text-transform: uppercase;\n    letter-spacing: 2px;\n    color: #00F2FE !important;\n    text-shadow: 0 0 8px rgba(0, 242, 254, 0.6) !important;\n  }\n  @keyframes neonPulse {\n    0% { box-shadow: 0 0 5px #FF003C, inset 0 0 5px #FF003C; }\n    50% { box-shadow: 0 0 20px #FF003C, inset 0 0 10px #FF003C; }\n    100% { box-shadow: 0 0 5px #FF003C, inset 0 0 5px #FF003C; }\n  }\n  .status-critical { animation: neonPulse 1.5s infinite; border-color: #FF003C !important; }\n\nbody::after {\n  content: \" \";\n  display: block;\n  position: absolute;\n  top: 0; left: 0; bottom: 0; right: 0;\n  background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n  z-index: 2;\n  background-size: 100% 4px, 6px 100%;\n  pointer-events: none;\n}\n</style>\n<div style=\"display:flex; justify-content:space-between; align-items:center; height:100%; border-bottom: 2px solid #00F2FE; box-shadow: 0 2px 10px rgba(0,242,254,0.3); padding: 0 16px;\">\n  <div style=\"font-size:28px; font-weight:900; color:#fff; text-shadow: 0 0 10px #00F2FE, 0 0 20px #00F2FE; letter-spacing:4px;\">\n    APEX <span style=\"color:#00F2FE;\">NOC</span> SYNC\n  </div>\n  <div style=\"color:#00FF87; font-size:13px; text-shadow: 0 0 5px #00FF87;\">SYSTEM ONLINE // SECURE CONNECTION</div>\n</div>"
      },
      "datasource": null,
      "description": "Cyberpunk NOC command center banner with animated neon CSS theme."
    },
    {
      "id": 300,
      "type": "row",
      "title": "KEY METRICS (Real-Time)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "CPU Load (All Machines)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": 60000,
            "gradientMode": "opacity",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(?!.*TX|Upload|Z-Score).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#00FF87"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }}",
          "rawSql": "SELECT bucket AS time, machine_id, avg_cpu_load AS \"CPU Load %\" FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) AND machine_id IN (${machine_id:sqlstring}) ORDER BY 1",
          "format": "time_series"
        }
      ],
      "links": [
        {
          "title": "Drill-down \u2192 ${__field.labels.machine_id}",
          "url": "/d/ims-engineering?var-machine_id=${__field.labels.machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Real-time CPU utilization (%) for all machines, sampled every 10 seconds. Yellow >75%, Red >90%."
    },
    {
      "id": 21,
      "title": "Temperature (All Machines)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": 60000,
            "gradientMode": "opacity",
            "drawStyle": "line"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 45
              },
              {
                "color": "red",
                "value": 55
              }
            ]
          }
        },
        "overrides": [
