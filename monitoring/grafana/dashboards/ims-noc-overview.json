  "links": [
    {
      "title": "TV Kiosk Mode",
      "url": "/d/ims-noc-overview?orgId=1&kiosk=tv",
      "type": "link",
      "icon": "bolt",
      "targetBlank": true
    },
    {
      "title": "Engineering Drill-Down",
      "url": "/d/ims-engineering",
      "type": "link",
      "icon": "external link",
