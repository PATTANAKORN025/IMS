    {
      "id": 500,
      "type": "row",
      "title": "NETWORK HEALTH",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "collapsed": false
    },
    {
      "id": 22,
      "title": "Network Throughput (All Machines)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mbps",
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": true,
            "gradientMode": "scheme"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*RX.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#1F60C4",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*TX.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#5794F2",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }} RX",
          "rawSql": "SELECT bucket AS time, machine_id, avg_rx_mbps AS \"RX (Mbps)\" FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) AND machine_id IN (${machine_id:sqlstring}) ORDER BY 1",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }} TX",
          "rawSql": "SELECT bucket AS time, machine_id, avg_tx_mbps * -1 AS \"TX (Mbps)\" FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) AND machine_id IN (${machine_id:sqlstring}) ORDER BY 1",
          "format": "time_series"
        }
      ],
      "links": [
        {
          "title": "Drill Down to Engineering",
          "url": "/d/ims-engineering?var-machine_id=${__value.text}&from=${__from}&to=${__to}",
          "type": "link",
          "icon": "external link",
          "targetBlank": true
        }
      ]
    },
