      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": 60000,
            "gradientMode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ERP-MASTER-UBUNTU"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF6B35",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ERP-MASTER-WINDOWS"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#4ECDC4",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }}",
          "rawSql": "SELECT bucket AS time, machine_id, avg_cpu_load AS \"CPU Load %\" FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) AND machine_id IN (${machine_id:sqlstring}) ORDER BY 1",
          "format": "time_series"
        }
      ],
      "links": [
        {
          "title": "Drill-down \u2192 ${__field.labels.machine_id}",
          "url": "/d/ims-engineering?var-machine_id=${__field.labels.machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Real-time CPU utilization (%) for all machines, sampled every 10 seconds. Yellow >75%, Red >90%."
