    {
      "title": "AIOps & Capacity",
      "url": "/d/ims-capacity",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT machine_id FROM public.machine_telemetry ORDER BY machine_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Machine"
      },
      {
        "name": "interface",
        "type": "query",
        "query": "SELECT DISTINCT key FROM (SELECT interface_metrics FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '10 minutes' ORDER BY time DESC LIMIT 100) AS recent, jsonb_object_keys(recent.interface_metrics) AS key ORDER BY key",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Interface"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
