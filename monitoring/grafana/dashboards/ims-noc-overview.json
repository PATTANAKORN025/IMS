      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 3,
            "spanNulls": 60000,
            "gradientMode": "opacity",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
