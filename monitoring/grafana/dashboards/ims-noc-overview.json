    {
      "id": 20,
      "title": "CPU Load (All Machines)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": 60000,
            "gradientMode": "opacity",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(?!.*TX|Upload|Z-Score).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#00FF87"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }}",
          "rawSql": "SELECT bucket AS time, machine_id, avg_cpu_load AS \"CPU Load %\" FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) AND machine_id IN (${machine_id:sqlstring}) ORDER BY 1",
          "format": "time_series"
        }
      ],
      "links": [
