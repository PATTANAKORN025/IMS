              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*UBUNTU.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#00FF87"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*WINDOWS.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#00F2FE"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*DB.*|(?i).*TIMESCALE.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#7F00FF"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*(Forecast|Regression|Linear).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#4A5568"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
