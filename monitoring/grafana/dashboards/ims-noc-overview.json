      "transparent": true,
      "options": {
        "mode": "html",
        "content": "<div style=\"font-family:Rajdhani,monospace; padding:8px; background:rgba(0,0,0,0.3); border-radius:12px; border:1px solid rgba(0,242,254,0.15);\">\n<div style=\"text-align:center; color:#00F2FE; font-size:13px; letter-spacing:3px; margin-bottom:6px; text-shadow:0 0 8px rgba(0,242,254,0.5);\">FLEET HEXMAP</div>\n<svg viewBox=\"0 0 400 120\" style=\"width:100%; max-height:100px;\">\n  <defs>\n    <linearGradient id=\"hg1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0%\" stop-color=\"#00FF87\"/><stop offset=\"100%\" stop-color=\"#00CC6A\"/></linearGradient>\n    <linearGradient id=\"hg2\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0%\" stop-color=\"#FF9100\"/><stop offset=\"100%\" stop-color=\"#FF6D00\"/></linearGradient>\n    <linearGradient id=\"hg3\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0%\" stop-color=\"#FF003C\"/><stop offset=\"100%\" stop-color=\"#CC0030\"/></linearGradient>\n    <linearGradient id=\"hg4\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0%\" stop-color=\"#00F2FE\"/><stop offset=\"100%\" stop-color=\"#00B8D4\"/></linearGradient>\n    <filter id=\"hexglow\"><feGaussianBlur stdDeviation=\"1.5\" result=\"b\"/><feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>\n  </defs>\n  <!-- Row 1 -->\n  <g transform=\"translate(40,30)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">S00</text>\n  </g>\n  <g transform=\"translate(88,30)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">S01</text>\n  </g>\n  <g transform=\"translate(136,30)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg2)\" stroke=\"#FF9100\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">S02</text>\n  </g>\n  <g transform=\"translate(184,30)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">S03</text>\n  </g>\n  <g transform=\"translate(232,30)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">S04</text>\n  </g>\n  <g transform=\"translate(280,30)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg3)\" stroke=\"#FF003C\" stroke-width=\"1.5\" opacity=\"0.9\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#fff\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">S05</text>\n  </g>\n  <g transform=\"translate(328,30)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg4)\" stroke=\"#00F2FE\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">S06</text>\n  </g>\n  <!-- Row 2 (offset) -->\n  <g transform=\"translate(64,65)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">S07</text>\n  </g>\n  <g transform=\"translate(112,65)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">ERP</text>\n  </g>\n  <g transform=\"translate(160,65)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg2)\" stroke=\"#FF9100\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">DB</text>\n  </g>\n  <g transform=\"translate(208,65)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">NR</text>\n  </g>\n  <g transform=\"translate(256,65)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">GFX</text>\n  </g>\n  <g transform=\"translate(304,65)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">BB</text>\n  </g>\n  <!-- Row 3 -->\n  <g transform=\"translate(40,100)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg4)\" stroke=\"#00F2FE\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">P1</text>\n  </g>\n  <g transform=\"translate(88,100)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg4)\" stroke=\"#00F2FE\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">P2</text>\n  </g>\n  <g transform=\"translate(136,100)\" filter=\"url(#hexglow)\">\n    <polygon points=\"0,-25 22,-12.5 22,12.5 0,25 -22,12.5 -22,-12.5\" fill=\"url(#hg1)\" stroke=\"#00FF87\" stroke-width=\"1\" opacity=\"0.8\"/><text x=\"0\" y=\"4\" text-anchor=\"middle\" fill=\"#000\" font-size=\"8\" font-family=\"Rajdhani\" font-weight=\"700\">AL</text>\n  </g>\n  <!-- Legend -->\n  <circle cx=\"220\" cy=\"108\" r=\"5\" fill=\"#00FF87\" opacity=\"0.8\"/><text x=\"230\" y=\"112\" fill=\"#889\" font-size=\"8\" font-family=\"Rajdhani\">Healthy</text>\n  <circle cx=\"280\" cy=\"108\" r=\"5\" fill=\"#FF9100\" opacity=\"0.8\"/><text x=\"290\" y=\"112\" fill=\"#889\" font-size=\"8\" font-family=\"Rajdhani\">Warning</text>\n  <circle cx=\"340\" cy=\"108\" r=\"5\" fill=\"#FF003C\" opacity=\"0.8\"/><text x=\"350\" y=\"112\" fill=\"#889\" font-size=\"8\" font-family=\"Rajdhani\">Critical</text>\n</svg>\n</div>"
      },
