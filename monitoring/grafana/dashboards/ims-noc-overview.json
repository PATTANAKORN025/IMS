              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF9100"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }}",
          "rawSql": "SELECT bucket AS time, machine_id, max_temp AS \"Temperature (\u00b0C)\" FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) AND machine_id IN (${machine_id:sqlstring}) AND max_temp > 0 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "links": [
        {
          "title": "Drill Down to Engineering",
          "url": "/d/ims-engineering?var-machine_id=${__field.labels.machine_id}&from=${__from}&to=${__to}",
          "type": "link",
          "icon": "external link",
          "targetBlank": true
        }
      ],
      "description": "Real-time temperature (\u00b0C) for all machines. Yellow >70\u00b0C, Red >85\u00b0C."
    },
    {
