        "y": 0
      },
      "options": {
        "mode": "html",
        "content": "<style>\n@import url(\"https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap\");\n.dashboard-page { background: #050505 !important; font-family: 'Rajdhani', sans-serif !important; }\n.panel-container {\n  position: relative;\n  background: #0D1117 !important;\n  border: 1px solid #1F2937 !important;\n  border-radius: 0px !important;\n  box-shadow: 0 4px 6px rgba(0,0,0,0.3) !important;\n}\n.panel-container::before {\n  content: \"\"; position: absolute; bottom: 0; left: 0; width: 100%; height: 2px;\n  background: linear-gradient(90deg, #00F2FE, #00FF87);\n}\n.panel-title { color: #A0AEC0 !important; font-size: 13px !important; text-transform: uppercase; }\n</style><div style=\"display:flex;align-items:center;gap:0;height:100%;padding:0;\n  background:#0D1117;border-bottom:2px solid #1F2937;font-family:'Rajdhani',sans-serif;\">\n  <div style=\"padding:0 16px;font-size:20px;font-weight:700;color:#E5E7EB;letter-spacing:3px;\n    border-right:1px solid #1F2937;white-space:nowrap;\">APEX <span style=\"color:#00F2FE\">CMD</span></div>\n  <div style=\"padding:0 12px;color:#6B7280;font-size:11px;letter-spacing:1px;\">SYSTEM ONLINE</div>\n  <div style=\"flex:1\"></div>\n  <a href=\"/d/ims-noc-overview\" target=\"_blank\"\n    style=\"padding:6px 16px;font-size:12px;font-weight:700;letter-spacing:1px;text-decoration:none;\n    color:#00F2FE;border-bottom:2px solid #00F2FE;transition:background 0.3s;\n    background:#0D1117;\">NOC</a>\n  <a href=\"/d/ims-engineering\" target=\"_blank\"\n    style=\"padding:6px 16px;font-size:12px;font-weight:700;letter-spacing:1px;text-decoration:none;\n    color:#889;border-bottom:2px solid #1F2937;transition:background 0.3s;\n    onmouseover='this.style.background=\"#111827\"' onmouseout='this.style.background=\"transparent\"'\">ENG</a>\n  <a href=\"/d/ims-capacity\" target=\"_blank\"\n    style=\"padding:6px 16px;font-size:12px;font-weight:700;letter-spacing:1px;text-decoration:none;\n    color:#889;border-bottom:2px solid #1F2937;transition:background 0.3s;\n    onmouseover='this.style.background=\"#111827\"' onmouseout='this.style.background=\"transparent\"'\">CAP</a>\n</div>"
      },
      "datasource": null,
      "transparent": true,
      "description": "OS Taskbar navigation and CSS theme."
