        "x": 0,
        "y": 18
      },
      "options": {
        "mode": "html",
        "content": "<style>\n@import url(\"https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap\");\n.dashboard-page {\n  background: radial-gradient(circle at center, #0B0E14 0%, #040508 100%),\n              linear-gradient(0deg, transparent 24%, rgba(0,242,254,0.03) 25%, rgba(0,242,254,0.03) 26%, transparent 27%),\n              linear-gradient(90deg, transparent 24%, rgba(0,242,254,0.03) 25%, rgba(0,242,254,0.03) 26%, transparent 27%) !important;\n  background-size: 100% 100%, 50px 50px, 50px 50px !important;\n  font-family: 'Rajdhani', sans-serif !important;\n}\n.panel-container {\n  background: linear-gradient(135deg, rgba(11,14,20,0.8) 0%, rgba(15,20,30,0.5) 100%) !important;\n  border: 1px solid rgba(0,242,254,0.15) !important;\n  box-shadow: 0 4px 30px rgba(0,0,0,0.5), inset 0 0 20px rgba(0,242,254,0.05) !important;\n  backdrop-filter: blur(12px) !important;\n  border-radius: 12px !important;\n}\n.panel-title {\n  font-family: 'Rajdhani', sans-serif !important;\n  font-weight: 700; letter-spacing: 2px;\n  color: #00F2FE !important;\n  transition: text-shadow 0.3s ease-in-out;\n}\n.panel-title:hover {\n  text-shadow: 2px 0 #FF003C, -2px 0 #00F2FE !important;\n}\n.react-grid-item { padding: 5px !important; }\n.panel-container:hover {\n  transform: scale(1.01);\n  transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  cursor: pointer;\n}\n@keyframes fluidPulse {\n  0% { filter: drop-shadow(0 0 5px #FF003C); opacity: 0.8; }\n  50% { filter: drop-shadow(0 0 20px #FF003C); opacity: 1; }\n  100% { filter: drop-shadow(0 0 5px #FF003C); opacity: 0.8; }\n}\n.status-critical { animation: fluidPulse 2s cubic-bezier(0.4, 0, 0.2, 1) infinite; }\n</style><div style=\"display:flex;justify-content:space-between;align-items:center;height:100%;border-bottom:2px solid #00F2FE;box-shadow:0 2px 15px rgba(0,242,254,0.4);padding:0 16px;\"><div style=\"font-size:32px;font-weight:700;color:#fff;text-shadow:0 0 15px #00F2FE;letter-spacing:5px;font-family:Rajdhani,sans-serif;\">APEX <span style=\"color:#00F2FE;\">COMMAND</span></div><div style=\"color:#00FF87;font-size:13px;text-shadow:0 0 5px #00FF87;\">SYSTEM ONLINE // SECURE</div></div>"
      },
      "datasource": null,
      "description": "Cyberpunk NOC command center banner with animated neon CSS theme.",
      "transparent": true
    },
