{
  "uid": "ims-noc-overview",
  "title": "IMS NOC Overview",
  "tags": [
    "ims",
    "noc"
  ],
  "timezone": "Asia/Bangkok",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "links": [
    {
      "title": "TV Kiosk Mode",
      "url": "/d/ims-noc-overview?orgId=1&kiosk=tv",
      "type": "link",
      "icon": "bolt",
      "targetBlank": true
    },
    {
      "title": "Engineering Drill-Down",
      "url": "/d/ims-engineering",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    },
    {
      "title": "AIOps & Capacity",
      "url": "/d/ims-capacity",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT machine_id FROM public.machine_telemetry ORDER BY machine_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Machine"
      },
      {
        "name": "interface",
        "type": "query",
        "query": "SELECT DISTINCT key FROM (SELECT interface_metrics FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '10 minutes' ORDER BY time DESC LIMIT 100) AS recent, jsonb_object_keys(recent.interface_metrics) AS key ORDER BY key",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Interface"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 999,
      "type": "grafana-clock-panel",
      "title": "",
      "datasource": null,
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "clock",
        "clockType": "24hour",
        "pendulum": false,
        "showDate": true,
        "dateSettings": {
          "dateFormat": "YYYY-MM-DD",
          "locale": "en",
          "timeZone": "Asia/Bangkok"
        },
        "timeSettings": {
          "showSeconds": true,
          "showHour": true,
          "showMinutes": true,
          "timeFormat": "24"
        },
        "timezone": "Asia/Bangkok",
        "bgColor": "transparent"
      },
      "description": "Current time and date (Asia/Bangkok timezone)."
    },
    {
      "id": 998,
      "type": "alertlist",
      "title": "Active Alerts",
      "description": "Currently firing alerts from Grafana unified alerting.",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "showOptions": "current",
        "sortOrder": 1,
        "stateFilter": {
          "firing": true,
          "pending": false,
          "noData": false,
          "normal": false,
          "error": false
        },
        "alertName": "",
        "dashboardAlerts": false,
        "folder": null
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "FLEET OVERVIEW",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Machines Online",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background-solid",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT COUNT(DISTINCT machine_id) AS value FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '5 minutes'",
          "format": "table"
        }
      ],
      "description": "Number of machines reporting telemetry within the last 5 minutes."
    },
    {
      "id": 4,
      "title": "Fleet Health Score",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background-solid",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT 'Fleet Score' AS metric, value FROM public.v_fleet_score",
          "format": "table"
        }
      ],
      "description": "Composite fleet health score (0-100%) from v_fleet_health view. Red <70%, Yellow <90%, Green \u226590%."
    },
    {
      "id": 601,
      "title": "LDI Yield Risk (% Outside Tolerance)",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background-solid",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH ldi AS (SELECT machine_id, ldi_pe, ldi_je FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '1 hour' AND ldi_pe IS NOT NULL) SELECT ROUND(100.0 * SUM(CASE WHEN ABS(ldi_pe) > 10 OR ABS(ldi_je) > 10 THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0)::NUMERIC, 1) AS value FROM ldi",
          "format": "table"
        }
      ],
      "description": "Percentage of LDI readings exceeding \u00b110\u00b5m tolerance in the last hour. Green <5%, Yellow <15%, Red \u226515%."
    },
    {
      "id": 602,
      "title": "Power Cost Estimation (THB/day)",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyTHB",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH power_data AS (SELECT machine_id, AVG(ldi_power) AS avg_watts FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '1 day' AND ldi_power IS NOT NULL GROUP BY machine_id) SELECT 'Fleet Power Cost' AS metric, ROUND(SUM(avg_watts * 24 * 4.5 / 1000)::NUMERIC, 0) AS value FROM power_data",
          "format": "table"
        }
      ],
      "description": "Estimated daily power cost in Thai Baht based on average LDI power consumption \u00d7 24 hours \u00d7 4.5 THB/kWh."
    },
    {
      "id": 200,
      "type": "row",
      "title": "FLEET STATUS TABLE",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Server Fleet Status",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "online": {
                        "color": "green",
                        "text": "online"
                      },
                      "stale": {
                        "color": "yellow",
                        "text": "stale"
                      },
                      "offline": {
                        "color": "red",
                        "text": "offline"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Last Update"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "unit",
                "value": "dateTimeFromNow"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CPU (%)"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 80
                    },
                    {
                      "color": "red",
                      "value": 90
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Temp (\u00b0C)"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 45
                    },
                    {
                      "color": "red",
                      "value": 55
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Status",
            "desc": false
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT machine_id AS \"Server Name\", CASE WHEN MAX(time) > NOW() - INTERVAL '2 minutes' THEN 'online' WHEN MAX(time) > NOW() - INTERVAL '10 minutes' THEN 'stale' ELSE 'offline' END AS \"Status\", ROUND(AVG(cpu_load_percent)::NUMERIC, 1) AS \"CPU (%)\", ROUND(AVG(temp_c)::NUMERIC, 0) AS \"Temp (\u00b0C)\", MAX(time) AS \"Last Update\" FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '10 minutes' GROUP BY machine_id ORDER BY machine_id",
          "format": "table"
        }
      ],
      "links": [
        {
          "title": "Drill-down \u2192 Engineering: ${__data.fields[\"Server Name\"]}",
          "url": "/d/ims-engineering?var-machine_id=${__data.fields[\"Server Name\"]}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Real-time fleet status table showing each machine's CPU, RAM, disk, temperature, network, and LDI health. Click machine name to drill down."
    },
    {
      "id": 300,
      "type": "row",
      "title": "KEY METRICS (Real-Time)",
