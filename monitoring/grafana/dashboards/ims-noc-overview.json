      "options": {
        "mode": "html",
        "content": "<style>\n.dashboard-page { background: #0a0b10 !important; }\n.panel-container {\n  position: relative;\n  background: rgba(13, 17, 23, 0.85) !important;\n  border: 1px solid rgba(0, 242, 254, 0.2) !important;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.4) !important;\n  backdrop-filter: blur(4px) !important;\n  border-radius: 4px !important;\n  transition: box-shadow 0.2s ease;\n}\n.panel-container:hover {\n  box-shadow: 0 2px 12px rgba(0,242,254,0.1) !important;\n}\n@keyframes scanline {\n  0% { transform: translateY(-100%); }\n  100% { transform: translateY(1000%); }\n}\n.panel-container::after {\n  content: \"\"; position: absolute; top: 0; left: 0; right: 0; height: 1px;\n  background: rgba(0,242,254,0.3);\n  pointer-events: none;\n}\n.panel-title { color: #A0AEC0 !important; font-size: 12px !important; text-transform: uppercase; }\n</style>\n<div style=\"display:flex;justify-content:space-between;align-items:center;padding:0 10px;height:100%;\">\n  <span style=\"font-family:Consolas,Courier New,monospace;font-size:16px;font-weight:bold;color:#00F2FE;\">APEX COMMAND HUB</span>\n  <div style=\"display:flex;gap:15px;\">\n    <a href=\"/d/ims-noc-overview\" style=\"color:#00FF87;text-decoration:none;font-size:14px;font-family:Consolas,monospace;\">[ NOC ]</a>\n    <a href=\"/d/ims-engineering\" style=\"color:#FF9100;text-decoration:none;font-size:14px;font-family:Consolas,monospace;\">[ ENG ]</a>\n    <a href=\"/d/ims-capacity\" style=\"color:#7F00FF;text-decoration:none;font-size:14px;font-family:Consolas,monospace;\">[ CAP ]</a>\n  </div>\n</div>"
