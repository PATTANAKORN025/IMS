                  "mode": "fixed",
                  "fixedColor": "#00FF87"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "{{ machine_id }}",
          "rawSql": "SELECT bucket AS time, machine_id, avg_cpu_load AS \"CPU Load %\" FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) AND machine_id IN (${machine_id:sqlstring}) ORDER BY 1",
          "format": "time_series"
        }
      ],
      "links": [
        {
          "title": "Drill-down \u2192 ${__field.labels.machine_id}",
          "url": "/d/ims-engineering?var-machine_id=${__field.labels.machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        },
        {
          "title": "Drill-down \u2192 Engineering",
          "url": "/d/ims-engineering?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Real-time CPU utilization (%) for all machines, sampled every 10 seconds. Yellow >75%, Red >90%.",
