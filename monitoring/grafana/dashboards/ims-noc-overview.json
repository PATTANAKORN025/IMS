          "refId": "AVG",
          "legendFormat": "Fleet Average",
          "rawSql": "SELECT bucket AS time, ROUND(AVG(avg_cpu_load)::NUMERIC,1) AS value FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) GROUP BY bucket ORDER BY 1",
          "format": "time_series",
