{
  "uid": "ldi-pcb-manufacturing",
  "title": "IMS LDI — PCB Manufacturing Fleet",
  "description": "Laser Direct Imaging monitoring dashboard for PCB photoresist manufacturing. 15 panels across 4 functional rows: Executive KPI, Process Control, Performance AIOps, and Fleet Triage.",
  "tags": [
    "ims",
    "ldi",
    "manufacturing"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT device_id AS __text FROM public.ldi_metrics WHERE $__timeFilter(time) ORDER BY device_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Machine"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 101,
      "title": "Fleet Uptime Status",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#10B981",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "text": {
          "valueSize": 36,
          "titleSize": 12
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT COUNT(DISTINCT device_id) AS value FROM public.ldi_metrics WHERE $__timeFilter(time) AND throughput > 0",
          "format": "table"
        }
      ],
      "description": "Count of LDI machines reporting active throughput. Green = at least 1 active, Red = all idle.",
      "transparent": true
    },
    {
      "id": 102,
      "title": "Fleet Status Table",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 20,
        "h": 8
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Last Seen",
            "desc": true
          }
        ],
        "rowHeight": 0.4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH latest AS (SELECT device_id, MAX(time) AS last_seen FROM public.ldi_metrics WHERE $__timeFilter(time) GROUP BY device_id) SELECT l.device_id AS \"Machine\", ROUND(s.throughput::NUMERIC, 1) AS \"Throughput\", ROUND(s.temperature::NUMERIC, 1) AS \"Temp (°C)\", ROUND(s.humidity::NUMERIC, 1) AS \"Humidity (%)\", ROUND(s.power_watt::NUMERIC, 0) AS \"Power (W)\", CASE WHEN l.last_seen > NOW() - INTERVAL '1 minute' THEN 'online' WHEN l.last_seen > NOW() - INTERVAL '5 minutes' THEN 'stale' ELSE 'offline' END AS \"Status\" FROM latest l LEFT JOIN public.ldi_metrics s ON s.device_id = l.device_id AND s.time = l.last_seen WHERE l.last_seen IS NOT NULL ORDER BY l.last_seen DESC LIMIT 10",
          "format": "table"
        }
      ],
      "description": "Latest metrics per LDI machine with dynamic online/stale/offline status.",
      "transparent": true
    },
    {
