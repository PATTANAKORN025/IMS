            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id || ' - Avg JE' AS metric, ROUND(AVG((COALESCE(je_1,0)+COALESCE(je_2,0)+COALESCE(je_3,0)+COALESCE(je_4,0))/NULLIF(CASE WHEN je_1 IS NOT NULL THEN 1 ELSE 0 END+CASE WHEN je_2 IS NOT NULL THEN 1 ELSE 0 END+CASE WHEN je_3 IS NOT NULL THEN 1 ELSE 0 END+CASE WHEN je_4 IS NOT NULL THEN 1 ELSE 0 END,0))::NUMERIC, 1) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND (je_1 IS NOT NULL OR je_2 IS NOT NULL) GROUP BY time_bucket($__interval, time), eqp_id ORDER BY 1 ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket($__interval, time) AS time, eqp_id || ' - JE Setting' AS metric, ROUND(AVG(je_setting)::NUMERIC, 1) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND je_setting IS NOT NULL GROUP BY 1, eqp_id ORDER BY 1 ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "Average Junction Efficiency vs JE Setting threshold. Dashed amber = target."
    },
