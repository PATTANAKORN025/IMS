            "uid": "timescaledb"
          },
          "rawSql": "WITH latest AS (SELECT device_id, MAX(time) AS last_seen FROM public.ldi_metrics WHERE $__timeFilter(time) GROUP BY device_id) SELECT l.device_id AS \"Machine\", ROUND(s.throughput::NUMERIC, 1) AS \"Throughput\", ROUND(s.temperature::NUMERIC, 1) AS \"Temp (°C)\", ROUND(s.humidity::NUMERIC, 1) AS \"Humidity (%)\", ROUND(s.pressure::NUMERIC, 2) AS \"Pressure\", ROUND(s.vibration::NUMERIC, 3) AS \"Vibration\", ROUND(s.power_watt::NUMERIC, 0) AS \"Power (W)\", CASE WHEN l.last_seen > NOW() - INTERVAL '1 minute' THEN 'online' WHEN l.last_seen > NOW() - INTERVAL '5 minutes' THEN 'stale' ELSE 'offline' END AS \"Status\" FROM latest l LEFT JOIN public.ldi_metrics s ON s.device_id = l.device_id AND s.time = l.last_seen WHERE l.last_seen IS NOT NULL ORDER BY l.last_seen DESC",
          "format": "table"
        }
      ],
      "description": "Full fleet status with all LDI metrics per device. Dynamic online/stale/offline status based on data freshness.",
      "transparent": true
    },
