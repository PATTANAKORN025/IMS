    {
      "id": 8,
      "title": "Cycle Time Distribution",
      "type": "heatmap",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            },
            "showCellBorders": true,
            "stacking": {
              "mode": "none"
            },
            "fillOpacity": 80,
            "cellGap": 1
          },
          "color": {
            "mode": "scheme",
            "scheme": "YlOrRd"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "calculate": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('1 minute', time) AS time, ROUND((total_time / NULLIF(total_board, 0))::NUMERIC, 0) AS metric, COUNT(*) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND total_board > 0 AND total_time IS NOT NULL GROUP BY 1, 2 ORDER BY time ASC",
          "format": "time_series"
        }
      ],
      "transparent": true
    },
    {
      "id": 9,
      "title": "Z-Score Anomaly Matrix",
      "type": "state-timeline",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "ANOMALY",
                  "color": "#EF4444"
                },
                "1": {
                  "text": "WATCH",
                  "color": "#F59E0B"
                },
                "2": {
                  "text": "SAFE",
                  "color": "#10B981"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 1
              },
              {
                "color": "#10B981",
                "value": 2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "center",
        "rowHeight": 0.85,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH stats AS (SELECT eqp_id, AVG(temperature) AS mu, STDDEV(temperature) AS sigma FROM public.ldi_data WHERE time > NOW() - INTERVAL '24 hours' GROUP BY eqp_id) SELECT d.time, d.eqp_id AS metric, CASE WHEN ABS((d.temperature - s.mu) / NULLIF(s.sigma, 0)) > 3 THEN 0 WHEN ABS((d.temperature - s.mu) / NULLIF(s.sigma, 0)) > 2.5 THEN 1 ELSE 2 END AS value FROM public.ldi_data d JOIN stats s ON d.eqp_id = s.eqp_id WHERE $__timeFilter(d.time) AND d.temperature IS NOT NULL AND s.sigma > 0 ORDER BY d.time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true
    },
    {
      "id": 10,
      "title": "Unified Command Log",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "OK": {
                        "color": "#10B981",
                        "text": "OK"
                      },
                      "Warning": {
                        "color": "#F59E0B",
                        "text": "Warning"
                      },
                      "Error": {
                        "color": "#EF4444",
                        "text": "Error"
                      },
                      "alarm": {
                        "color": "#EF4444",
                        "text": "ALARM"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Alarms"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "range",
                    "options": {
                      "from": 1,
                      "result": {
                        "color": "#EF4444",
                        "text": "ALARM"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Alarms",
            "desc": true
          }
        ],
        "rowHeight": 0.6
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH latest_job AS (SELECT DISTINCT ON (eqp_id) eqp_id, mo, layer_name, board_no, total_board, time FROM public.ldi_data WHERE $__timeFilter(time) ORDER BY eqp_id, time DESC), latest_alarm AS (SELECT DISTINCT ON (a.equipmentid) a.equipmentid, COALESCE(m.alarm_msg, a.errorcode::TEXT) AS alarm_msg, COALESCE(m.alarm_type, 'OK') AS alarm_type FROM public.ldi_alarm_log a LEFT JOIN public.ldi_alarm_ms_code m ON a.errorcode = m.alarm_code WHERE a.logdate > NOW() - INTERVAL '1 hour' ORDER BY a.equipmentid, a.logdate DESC), alarm_counts AS (SELECT equipmentid, COUNT(*) AS cnt FROM public.ldi_alarm_log WHERE logdate > NOW() - INTERVAL '1 hour' GROUP BY equipmentid) SELECT j.eqp_id AS \"Machine\", j.mo AS \"Job\", j.layer_name AS \"Layer\", (j.board_no || '/' || j.total_board) AS \"Progress\", COALESCE(a.alarm_msg, 'None') AS \"Alarm\", COALESCE(a.alarm_type, 'OK') AS \"Status\", COALESCE(c.cnt, 0) AS \"Alarms\" FROM latest_job j LEFT JOIN latest_alarm a ON j.eqp_id = a.equipmentid LEFT JOIN alarm_counts c ON j.eqp_id = c.equipmentid ORDER BY COALESCE(c.cnt, 0) DESC, j.eqp_id",
          "format": "table"
        }
      ],
      "transparent": true
    }
  ],
  "style": "dark"
}