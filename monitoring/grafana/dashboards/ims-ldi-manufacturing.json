      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH stats AS (SELECT eqp_id, AVG(temperature) AS mu, STDDEV(temperature) AS sigma FROM public.ldi_data WHERE time > NOW() - INTERVAL '24 hours' AND eqp_id IN (${machine_id:singlequote}) AND temperature IS NOT NULL GROUP BY eqp_id) SELECT d.time, d.eqp_id AS metric, ROUND((d.temperature - s.mu) / NULLIF(s.sigma, 0)::NUMERIC, 2) AS \"Z-Score\" FROM public.ldi_data d JOIN stats s ON d.eqp_id = s.eqp_id WHERE d.time > NOW() - INTERVAL '24 hours' AND d.eqp_id IN (${machine_id:singlequote}) AND d.temperature IS NOT NULL ORDER BY d.time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "description": "3-sigma Z-Score for temperature. Green: -2 to +2 (normal). Amber: +/-2.5 (approaching). Red: +/-3+ (anomaly). Uses 24h rolling baseline.",
