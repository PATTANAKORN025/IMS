          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id AS metric, ROUND(AVG(temperature)::NUMERIC, 2) AS \"Temperature\" FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND temperature IS NOT NULL GROUP BY time, eqp_id ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "Temperature per machine over time with threshold bands."
    },
