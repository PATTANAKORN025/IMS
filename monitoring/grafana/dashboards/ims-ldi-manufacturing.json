      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH stats AS (SELECT AVG(temperature) AS mu, STDDEV(temperature) AS sigma FROM public.ldi_data WHERE eqp_id = ${machine_id:singlequote} AND time > NOW() - INTERVAL '24 hours') SELECT d.time, ROUND(((d.temperature - s.mu) / NULLIF(s.sigma, 0))::NUMERIC, 2) AS \"Z-Score\" FROM public.ldi_data d, stats s WHERE d.eqp_id = ${machine_id:singlequote} AND $__timeFilter(d.time) AND d.temperature IS NOT NULL ORDER BY d.time ASC",
          "format": "time_series",
          "legendFormat": "Z-Score"
        }
      ],
      "description": "3-sigma Z-Score. Green -2 to +2, Amber 2.5, Red 3+.",
      "transparent": true
