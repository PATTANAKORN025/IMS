      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT humidity::NUMERIC AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND humidity IS NOT NULL ORDER BY time DESC LIMIT 1",
          "format": "time_series"
        }
      ],
      "transparent": true,
      "description": "Latest cleanroom humidity. Target 55%. Green 50-60, Amber 45/60, Red <45/>65."
    },
    {
      "id": 102,
      "title": "Active Production Jobs",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Last Seen",
            "desc": true
          }
        ],
        "rowHeight": 0.5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT DISTINCT ON (d.eqp_id) d.eqp_id AS \"Machine\", d.mo AS \"MO\", d.layer_name AS \"Layer\", d.total_time::INTEGER AS \"Cycle Time (s)\", d.total_board AS \"Boards\", d.time AS \"Last Seen\" FROM public.ldi_data d WHERE d.time > (SELECT MAX(time) - INTERVAL '5 minutes' FROM public.ldi_data) AND d.eqp_id IN (${machine_id:singlequote}) ORDER BY d.eqp_id, d.time DESC",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Latest production job per machine with MO, layer, and cycle time."
    },
    {
      "id": 201,
      "title": "Thermal Drift Map",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 12,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 19
