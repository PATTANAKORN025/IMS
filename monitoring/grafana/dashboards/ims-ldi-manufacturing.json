          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id || ' - Vacuum' AS metric, ROUND(AVG(air_vacuum)::NUMERIC, 2) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND air_vacuum IS NOT NULL GROUP BY time, eqp_id ORDER BY time ASC",
          "format": "time_series",
