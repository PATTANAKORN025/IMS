      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 12,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 19
              },
              {
                "color": "#10B981",
                "value": 20
              },
              {
                "color": "#F59E0B",
                "value": 24
              },
              {
                "color": "#EF4444",
                "value": 25
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id AS metric, temperature FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "description": "Temperature per machine. Green band 20-24C, Red outside.",
      "transparent": true
    },
