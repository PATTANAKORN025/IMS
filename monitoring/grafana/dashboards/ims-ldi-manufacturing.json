    {
      "id": 203,
      "title": "Resist Dosage vs Scan Speed",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 12,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Speed.*"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.axisLabel",
                "value": "Scan Speed"
              },
              {
                "id": "custom.drawStyle",
                "value": "line"
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Resist.*"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "left"
              },
              {
                "id": "custom.axisLabel",
                "value": "Resist Dosage"
              },
              {
                "id": "custom.drawStyle",
                "value": "bars"
              },
              {
                "id": "custom.fillOpacity",
                "value": 40
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id || ' - Resist Dosage' AS metric, ROUND(AVG(resist_dosage)::NUMERIC, 2) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND resist_dosage IS NOT NULL GROUP BY time, eqp_id ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id || ' - Scan Speed' AS metric, ROUND(AVG(scan_speed)::NUMERIC, 2) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND scan_speed IS NOT NULL GROUP BY time, eqp_id ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "Resist dosage (bars, left Y) vs scan speed (line, right Y) per machine."
    },
