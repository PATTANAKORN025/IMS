              {
                "color": "#F59E0B",
                "value": 45
              },
              {
                "color": "#10B981",
                "value": 50
              },
              {
                "color": "#F59E0B",
                "value": 60
              },
              {
                "color": "#EF4444",
                "value": 65
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
