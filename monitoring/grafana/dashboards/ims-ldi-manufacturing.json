{
  "uid": "ldi-pcb-manufacturing",
  "title": "IMS LDI — Apex Circuit Fleet Command Center",
  "description": "1920x1080 Kiosk Mode. 10 panels, 24-grid, zero scrolling. Executive HUD + ERP Sync + Compliance Matrix + AIOps + Triage.",
  "tags": [
    "ims",
    "ldi",
    "manufacturing",
    "kiosk",
    "isa101",
    "eemua191"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": true,
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Fleet Uptime",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#22C55E",
                "value": 100
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "text": {
          "valueSize": 48,
          "titleSize": 14
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT ROUND((COUNT(DISTINCT eqp_id) FILTER (WHERE state = true)::NUMERIC / NULLIF((SELECT COUNT(DISTINCT eqp_id) FROM public.ldi_data WHERE $__timeFilter(time)), 0)) * 100, 0) AS value FROM public.ldi_data WHERE $__timeFilter(time)",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Percentage of machines powered on and available for production."
    },
    {
      "id": 2,
      "title": "Avg Alignment Error (µm)",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthum",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#22C55E",
                "value": null
              },
              {
                "color": "#FACC15",
                "value": 10
              },
              {
                "color": "#EF4444",
                "value": 20
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH MaxPE AS (SELECT eqp_id, GREATEST(ABS(pe_1), ABS(pe_2), ABS(pe_3), ABS(pe_4), ABS(pe_5), ABS(pe_6)) AS max_error FROM public.ldi_data WHERE $__timeFilter(time) AND pe_1 IS NOT NULL) SELECT ROUND(AVG(max_error)::NUMERIC, 2) AS value FROM MaxPE",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Avg Alignment Error: mean of max absolute PE deviation across 6 fiducial points. Green <10µm, Amber 10-20µm, Red >20µm."
    },
    {
      "id": 3,
      "title": "Environmental Safety",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#FACC15",
                "value": 50
              },
              {
                "color": "#22C55E",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "text": {
          "valueSize": 48,
          "titleSize": 14
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE temperature BETWEEN 20 AND 24 AND humidity BETWEEN 50 AND 60) * 100.0 / NULLIF(COUNT(*), 0), 0) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND temperature IS NOT NULL AND humidity IS NOT NULL",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Environmental Safety: percentage of machines where temperature AND humidity are within safe bands."
    },
    {
      "id": 4,
      "title": "Active Critical Alarms",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#22C55E",
                "value": null
              },
              {
                "color": "#EF4444",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "text": {
          "valueSize": 48,
          "titleSize": 14
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT COUNT(*)::NUMERIC AS value FROM public.ldi_alarm_log a LEFT JOIN public.ldi_alarm_ms_code m ON a.errorcode::TEXT = m.alarm_code::TEXT WHERE a.logdate >= NOW() - INTERVAL '5 minutes' AND m.alarm_type ILIKE '%Critical%'",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Active Critical Alarms: count of alarms in the last 5 minutes only."
    },
    {
      "id": 5,
      "title": "Live Production Sync",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Machine",
            "desc": false
          }
        ],
        "rowHeight": 0.65
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT DISTINCT ON (eqp_id) eqp_id AS \"Machine\", mo AS \"Job (MO)\", fpn AS \"Part (FPN)\", layer_name AS \"Layer\", (board_no::TEXT || '/' || total_board::TEXT) AS \"Progress\" FROM public.ldi_data WHERE $__timeFilter(time) ORDER BY eqp_id, time DESC",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Machine Run State: per-machine RUNNING (green) / DOWN (red) timeline."
    },
    {
      "id": 6,
      "title": "Temperature Compliance (22±2°C)",
      "type": "state-timeline",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CRIT",
                  "color": "#EF4444"
                },
                "1": {
                  "text": "WARN",
                  "color": "#FACC15"
                },
                "2": {
                  "text": "OK",
                  "color": "#22C55E"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#FACC15",
                "value": 1
              },
              {
                "color": "#22C55E",
                "value": 2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "center",
        "rowHeight": 0.85,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id AS metric, CASE WHEN temperature BETWEEN 20 AND 24 THEN 2 WHEN temperature BETWEEN 19 AND 25 THEN 1 ELSE 0 END AS value FROM public.ldi_data WHERE $__timeFilter(time) AND temperature IS NOT NULL ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "Temperature Compliance: 3-color matrix — Green 20-24°C, Amber 19-25°C, Red outside."
    },
    {
      "id": 7,
      "title": "Humidity Compliance (55±5%)",
      "type": "state-timeline",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CRIT",
                  "color": "#EF4444"
                },
                "1": {
                  "text": "WARN",
                  "color": "#FACC15"
                },
                "2": {
                  "text": "OK",
                  "color": "#22C55E"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#FACC15",
                "value": 1
              },
              {
                "color": "#22C55E",
                "value": 2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "center",
        "rowHeight": 0.85,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id AS metric, CASE WHEN humidity BETWEEN 50 AND 60 THEN 2 WHEN humidity BETWEEN 45 AND 65 THEN 1 ELSE 0 END AS value FROM public.ldi_data WHERE $__timeFilter(time) AND humidity IS NOT NULL ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "Humidity Compliance: 3-color matrix — Green 50-60%, Amber 45-65%, Red outside."
    },
    {
      "id": 8,
      "title": "Avg Cycle Time (s/board)",
      "type": "heatmap",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            },
            "showCellBorders": true,
            "stacking": {
              "mode": "none"
            },
            "fillOpacity": 80,
            "cellGap": 1
          },
          "color": {
            "mode": "scheme",
            "scheme": "Reds"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('5 minutes', time) AS time, eqp_id AS metric, ROUND(AVG(total_time / NULLIF(total_board, 0))::NUMERIC, 2) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND total_board > 0 GROUP BY 1, 2 ORDER BY time",
          "format": "time_series"
        }
      ],
      "transparent": true,
      "description": "Avg Cycle Time: heatmap of seconds-per-board in 5-minute buckets. Hotter = slower."
    },
    {
      "id": 9,
      "title": "Thermal Z-Score Anomaly",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#22C55E",
                "value": -2
              },
              {
                "color": "#FACC15",
                "value": 2.5
              },
              {
                "color": "#EF4444",
                "value": 3
              }
            ]
          },
          "thresholdsStyle": {
            "mode": "line+area"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH stats AS (SELECT eqp_id, AVG(temperature) AS mu, STDDEV(temperature) AS sigma FROM public.ldi_data WHERE time > NOW() - INTERVAL '24 hours' GROUP BY eqp_id) SELECT d.time, d.eqp_id AS metric, ROUND(((d.temperature - s.mu) / NULLIF(s.sigma, 0))::NUMERIC, 2) AS \"Z-Score\" FROM public.ldi_data d JOIN stats s ON d.eqp_id = s.eqp_id WHERE $__timeFilter(d.time) AND d.temperature IS NOT NULL AND s.sigma > 0 ORDER BY d.time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "Thermal Z-Score: 3-sigma anomaly detection on temperature. Red if > 3σ."
    },
    {
      "id": 10,
      "title": "Unified Alarm Command Stream",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Critical": {
                        "color": "#EF4444",
                        "text": "Critical"
                      },
                      "Warning": {
                        "color": "#FACC15",
                        "text": "Warning"
                      },
                      "WARN": {
                        "color": "#FACC15",
                        "text": "Warning"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Time",
            "desc": true
          }
        ],
        "rowHeight": 0.6
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT a.logdate AS \"Time\", a.equipmentid AS \"Machine\", COALESCE(m.alarm_msg, a.errorcode::TEXT) AS \"Message\", COALESCE(m.alarm_type, 'WARN') AS \"Severity\" FROM public.ldi_alarm_log a LEFT JOIN public.ldi_alarm_ms_code m ON a.errorcode::TEXT = m.alarm_code::TEXT WHERE $__timeFilter(a.logdate) ORDER BY a.logdate DESC LIMIT 20",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Alarm Command Log: LEFT JOIN alarm_log with alarm codes. Color-coded severity."
    }
  ],
  "style": "dark"
}