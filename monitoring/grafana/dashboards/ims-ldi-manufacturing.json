    {
      "id": 304,
      "title": "Temperature Z-Score Anomaly",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 18,
        "y": 28,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#10B981",
                "value": -2
              },
              {
                "color": "#F59E0B",
                "value": 2.5
              },
              {
                "color": "#EF4444",
                "value": 3
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH stats AS (SELECT device_id, AVG(temperature) AS mu, STDDEV(temperature) AS sigma FROM public.ldi_metrics WHERE time > NOW() - INTERVAL '24 hours' AND device_id IN (${machine_id:singlequote}) AND temperature IS NOT NULL GROUP BY device_id) SELECT d.time, d.device_id AS metric, ROUND((d.temperature - s.mu) / NULLIF(s.sigma, 0)::NUMERIC, 2) AS \"Z-Score\" FROM public.ldi_metrics d JOIN stats s ON d.device_id = s.device_id WHERE d.time > NOW() - INTERVAL '24 hours' AND d.device_id IN (${machine_id:singlequote}) AND d.temperature IS NOT NULL ORDER BY d.time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "description": "3-sigma Z-Score for temperature anomaly detection. Green: -2 to +2 (normal). Amber: +/-2.5. Red: +/-3+ (anomaly).",
      "transparent": true
    },
