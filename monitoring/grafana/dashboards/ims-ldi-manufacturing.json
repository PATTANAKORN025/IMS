          "rawSql": "SELECT time, eqp_id AS metric, humidity FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "description": "Humidity per machine. Green band 50-60%, Red outside.",
