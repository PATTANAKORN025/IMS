          "rawSql": "SELECT ROUND(temperature::NUMERIC, 1) AS value FROM public.ldi_metrics WHERE $__timeFilter(time) AND device_id IN (${machine_id:singlequote}) AND temperature IS NOT NULL ORDER BY time DESC LIMIT 1",
          "format": "time_series"
        }
