    {
      "id": 304,
      "title": "Thermal Z-Score Anomaly",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 18,
        "y": 16,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#10B981",
                "value": -2
              },
              {
                "color": "#F59E0B",
                "value": 2.5
              },
              {
                "color": "#EF4444",
                "value": 3
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH rolling AS (SELECT time, eqp_id, temperature, AVG(temperature) OVER w AS mu, STDDEV(temperature) OVER w AS sigma FROM public.ldi_data WHERE time > NOW() - INTERVAL '24 hours' AND eqp_id IN (${machine_id:singlequote}) AND temperature IS NOT NULL WINDOW w AS (PARTITION BY eqp_id ORDER BY time ROWS BETWEEN 100 PRECEDING AND CURRENT ROW)) SELECT time, eqp_id AS metric, ROUND((temperature - mu) / NULLIF(sigma, 0)::NUMERIC, 2) AS \"Z-Score\" FROM rolling WHERE sigma IS NOT NULL AND sigma > 0 ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "3-sigma rolling Z-Score for temperature anomaly. Green normal, Red = anomaly."
    },
