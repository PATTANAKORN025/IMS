{
  "uid": "ldi-pcb-manufacturing",
  "title": "IMS LDI — Masterpiece Fleet Command Center",
  "description": "3-Column Kiosk Mode for 1920x1080 TV. Left: Fleet Vitals (Gauges). Center: Production Matrix (Table + Compliance). Right: AIOps & Triage (Heatmap + Alarms).",
  "tags": [
    "ims",
    "ldi",
    "manufacturing",
    "kiosk",
    "masterpiece"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": true,
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Fleet Uptime",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 50
              },
              {
                "color": "#10B981",
                "value": 80
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT ROUND(COUNT(DISTINCT eqp_id) FILTER (WHERE state = true) * 100.0 / NULLIF(COUNT(DISTINCT eqp_id), 0), 0) AS value FROM public.ldi_data WHERE $__timeFilter(time)",
          "format": "table"
        }
      ],
      "transparent": true
    },
    {
      "id": 2,
      "title": "Avg Temperature",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 15,
          "max": 35,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 19
              },
              {
                "color": "#10B981",
                "value": 20
              },
              {
                "color": "#F59E0B",
                "value": 24
              },
              {
                "color": "#EF4444",
                "value": 25
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT ROUND(AVG(temperature)::NUMERIC, 1) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND temperature IS NOT NULL",
          "format": "table"
        }
      ],
      "transparent": true
    },
    {
      "id": 3,
      "title": "Avg Humidity",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "humidity",
          "min": 30,
          "max": 80,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 45
              },
              {
                "color": "#10B981",
                "value": 50
              },
              {
                "color": "#F59E0B",
                "value": 60
              },
              {
                "color": "#EF4444",
                "value": 65
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT ROUND(AVG(humidity)::NUMERIC, 1) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND humidity IS NOT NULL",
          "format": "table"
        }
      ],
      "transparent": true
    },
    {
      "id": 4,
      "title": "Active Alarms",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 30,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#10B981",
                "value": null
              },
              {
                "color": "#EF4444",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT COUNT(*) AS value FROM public.ldi_alarm_log WHERE logdate > NOW() - INTERVAL '1 hour'",
          "format": "table"
        }
      ],
      "transparent": true
    },
    {
      "id": 5,
      "title": "Production Orders",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 10,
        "h": 8
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Machine",
            "desc": false
          }
        ],
        "rowHeight": 0.7
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT DISTINCT ON (eqp_id) eqp_id AS \"Machine\", mo AS \"MO (Job Order)\", fpn AS \"FPN\", layer_name AS \"Layer\", ROUND((total_time / NULLIF(total_board, 0))::NUMERIC, 1) AS \"Cycle Time\", (board_no::TEXT || '/' || total_board::TEXT) AS \"Progress\", time AS \"Last Update\" FROM public.ldi_data WHERE $__timeFilter(time) ORDER BY eqp_id, time DESC",
          "format": "table"
        }
      ],
      "transparent": true
    },
    {
      "id": 6,
      "title": "Temperature Compliance (22±2°C)",
      "type": "state-timeline",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 10,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CRIT",
                  "color": "#EF4444"
                },
                "1": {
                  "text": "WARN",
                  "color": "#F59E0B"
                },
                "2": {
                  "text": "OK",
                  "color": "#10B981"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 1
              },
              {
                "color": "#10B981",
                "value": 2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "center",
        "rowHeight": 0.85,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id AS metric, CASE WHEN temperature BETWEEN 20 AND 24 THEN 2 WHEN temperature BETWEEN 19 AND 25 THEN 1 ELSE 0 END AS value FROM public.ldi_data WHERE $__timeFilter(time) AND temperature IS NOT NULL ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true
    },
    {
      "id": 7,
      "title": "Humidity Compliance (55±5%)",
      "type": "state-timeline",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 6,
        "y": 14,
        "w": 10,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CRIT",
                  "color": "#EF4444"
                },
                "1": {
                  "text": "WARN",
                  "color": "#F59E0B"
                },
                "2": {
                  "text": "OK",
                  "color": "#10B981"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 1
              },
              {
                "color": "#10B981",
                "value": 2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "center",
        "rowHeight": 0.85,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id AS metric, CASE WHEN humidity BETWEEN 50 AND 60 THEN 2 WHEN humidity BETWEEN 45 AND 65 THEN 1 ELSE 0 END AS value FROM public.ldi_data WHERE $__timeFilter(time) AND humidity IS NOT NULL ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true
    },
    {
      "id": 8,
      "title": "Fault Frequency",
      "type": "heatmap",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            },
            "showCellBorders": true,
            "stacking": {
              "mode": "none"
            },
            "fillOpacity": 80,
            "cellGap": 1
          },
          "color": {
            "mode": "scheme",
            "scheme": "Oranges"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('5 minute', logdate) AS time, equipmentid AS metric, COUNT(*) AS value FROM public.ldi_alarm_log WHERE logdate > NOW() - INTERVAL '24 hours' GROUP BY 1, 2 ORDER BY time ASC",
          "format": "time_series"
        }
      ],
      "transparent": true
    },
    {
      "id": 9,
      "title": "Critical Alarms",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 16,
        "y": 9,
        "w": 8,
        "h": 10
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Error": {
                        "color": "#EF4444",
                        "text": "Error"
                      },
                      "Warning": {
                        "color": "#F59E0B",
                        "text": "Warning"
                      },
                      "UNK": {
                        "color": "#6B7280",
                        "text": "Unknown"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Time",
            "desc": true
          }
        ],
        "rowHeight": 0.5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT a.logdate AS \"Time\", a.equipmentid AS \"Machine\", COALESCE(m.alarm_msg, a.errorcode::TEXT) AS \"Message\", COALESCE(m.alarm_type, 'UNK') AS \"Severity\" FROM public.ldi_alarm_log a LEFT JOIN public.ldi_alarm_ms_code m ON a.errorcode = m.alarm_code WHERE a.logdate > NOW() - INTERVAL '24 hours' ORDER BY a.logdate DESC LIMIT 15",
          "format": "table"
        }
      ],
      "transparent": true
    }
  ],
  "style": "dark"
}