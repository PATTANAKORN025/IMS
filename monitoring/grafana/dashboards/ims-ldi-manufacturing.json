          },
          "rawSql": "WITH z AS (WITH stats AS (SELECT AVG(temperature) AS mu, STDDEV(temperature) AS sigma FROM public.ldi_metrics WHERE time > NOW() - INTERVAL '24 hours' AND temperature IS NOT NULL) SELECT COUNT(*) AS risk_count FROM public.ldi_metrics d, stats s WHERE d.time > NOW() - INTERVAL '1 hour' AND (ABS(d.temperature - s.mu) / NULLIF(s.sigma, 0)) > 2 AND d.temperature IS NOT NULL) SELECT ROUND(risk_count * 100.0 / NULLIF((SELECT COUNT(*) FROM public.ldi_metrics WHERE time > NOW() - INTERVAL '1 hour'), 0)::NUMERIC, 1) AS value FROM z",
          "format": "table"
        }
      ],
      "description": "Percentage of recent readings that deviate >2σ from the 24h baseline. High values indicate yield risk from thermal instability.",
