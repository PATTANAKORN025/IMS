      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT AVG(humidity) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND humidity IS NOT NULL",
          "format": "table"
        }
      ],
      "description": "Fleet average humidity. Green 50-60%, Amber 45/60, Red <45/>65.",
      "transparent": true
    },
    {
      "id": 5,
      "title": "Active Production Orders",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 18,
        "h": 4
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Machine",
            "desc": false
          }
        ],
        "rowHeight": 0.6
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT DISTINCT ON (eqp_id) eqp_id AS \"Machine\", mo AS \"Job Order\", layer_name AS \"Layer\", board_no AS \"Board #\", total_board AS \"Total\" FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) ORDER BY eqp_id, time DESC",
          "format": "table"
        }
      ],
      "description": "Latest production job per machine with board progress.",
      "transparent": true
    },
    {
      "id": 6,
      "title": "Alarms (1h)",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#10B981",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 5
              },
              {
                "color": "#EF4444",
                "value": 15
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "text": {
          "valueSize": 36,
          "titleSize": 14
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT COUNT(*) AS value FROM public.ldi_alarm_log WHERE $__timeFilter(logdate)",
          "format": "table"
        }
      ],
      "description": "Total alarms in time window. Green < 5, Amber 5-15, Red > 15.",
      "transparent": true
    },
    {
      "id": 7,
      "title": "Cleanroom Temperature Matrix (22±2°C)",
      "type": "timeseries",
      "datasource": {
