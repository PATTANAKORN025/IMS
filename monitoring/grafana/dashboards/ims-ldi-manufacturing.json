{
  "uid": "ldi-pcb-manufacturing",
  "title": "IMS LDI — PCB Manufacturing Command Center",
  "description": "15-panel AIOps Command Center for Laser Direct Imaging fleet. Data sourced from ldi_data, ldi_alarm_log, ldi_alarm_ms_code.",
  "tags": [
    "ims",
    "ldi",
    "manufacturing",
    "aiops"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT eqp_id AS __text, eqp_id AS __value FROM public.ldi_data WHERE $__timeFilter(time) ORDER BY eqp_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Machine"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 101,
      "title": "Fleet Uptime Status",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#10B981",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "text": {
          "valueSize": 40,
          "titleSize": 14
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT COUNT(DISTINCT eqp_id) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND state = true",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Count of online LDI machines (state=true). Green if >0, Red if 0."
    },
    {
      "id": 103,
      "title": "Cleanroom Temperature",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 15,
          "max": 35,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 19
              },
              {
                "color": "#10B981",
                "value": 20
              },
              {
                "color": "#F59E0B",
                "value": 24
              },
              {
                "color": "#EF4444",
                "value": 25
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT temperature::NUMERIC AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND temperature IS NOT NULL ORDER BY time DESC LIMIT 1",
          "format": "time_series"
        }
      ],
      "transparent": true,
      "description": "Latest cleanroom temperature. Target 22C. Green 20-24, Amber 19/24, Red <19/>25."
    },
    {
      "id": 104,
      "title": "Cleanroom Humidity",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "humidity",
          "min": 30,
          "max": 80,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
