      },
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "humidity",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 45
              },
              {
                "color": "#10B981",
                "value": 50
              },
              {
                "color": "#F59E0B",
                "value": 60
              },
              {
                "color": "#EF4444",
                "value": 65
              }
            ]
          },
          "thresholdsStyle": {
            "mode": "line+area"
          },
