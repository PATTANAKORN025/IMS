          "rawSql": "SELECT time_bucket('5 minutes', time) AS time, eqp_id AS metric, ROUND(AVG(total_time / NULLIF(total_board, 0))::NUMERIC, 2) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND total_board > 0 GROUP BY 1, 2 ORDER BY time",
