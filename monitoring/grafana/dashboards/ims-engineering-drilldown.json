    },
    {
      "id": 4,
      "title": "Temperature",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 45
              },
              {
                "color": "red",
                "value": 55
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT temp_c AS value FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '2 minutes' AND machine_id IN (${machine_id:sqlstring}) AND temp_c > 0 ORDER BY time DESC LIMIT 1",
          "format": "table"
        }
      ],
      "description": "Current temperature (°C) for the selected machine. Yellow >70°C, Red >85°C.",
      "transparent": true,
      "links": [
        {
          "title": "Drill-down → Engineering",
          "url": "/d/ims-engineering?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        },
        {
          "title": "Drill-down → Engineering",
          "url": "/d/ims-capacity?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 2000,
      "type": "row",
      "title": "Machine Summary",
      "repeat": "machine_id",
      "repeatDirection": "h",
      "maxPerRow": 2,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "collapsed": false,
      "transparent": true
    },
    {
      "id": 200,
      "type": "row",
      "title": "Time Series Analysis",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false,
      "transparent": true
    },
    {
      "id": 501,
      "title": "Memory Saturation",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 3,
            "spanNulls": 60000,
            "gradientMode": "opacity",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 85
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(?!.*TX|Upload).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#00F2FE"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "legendFormat": "RAM %",
          "rawSql": "SELECT bucket AS time, ROUND((avg_ram_used_mb / NULLIF(avg_ram_total_mb, 0) * 100)::NUMERIC, 1) AS \"RAM %\" FROM public.telemetry_minute_summary WHERE $__timeFilter(bucket) AND machine_id IN (${machine_id:sqlstring}) ORDER BY 1",
          "format": "time_series"
        }
      ],
      "description": "RAM utilization for the selected machine. Yellow at 75%, Red at 90%. Gapfilled via LOCF.",
      "transparent": true,
      "links": [
        {
          "title": "Drill-down → Engineering",
          "url": "/d/ims-engineering?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "Network & Environment",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false,
      "transparent": true
    },
    {
      "id": 502,
      "title": "Ethernet/WiFi Bandwidth (Per-Interface)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 20,
            "lineWidth": 3,
            "spanNulls": 60000,
            "gradientMode": "opacity",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "eth0 RX (bps)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#1F60C4",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "eth0 TX (bps)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#5794F2",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "wlan0 RX (bps)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8E24AA",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "wlan0 TX (bps)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#E02F44",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Upload.*"
            },
            "properties": [
              {
                "id": "custom.transform",
                "value": "negative-Y"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*TX|Upload|Upload.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF007F"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, (val->>'rx_mbps')::numeric * 1000000 AS \"Download (bps)\"\nFROM public.machine_telemetry,\nLATERAL jsonb_each(interface_metrics) AS iface(key, val)\nWHERE $__timeFilter(time)\n  AND machine_id IN (${machine_id:sqlstring})\n  AND iface.key IN (${interface:sqlstring})\nORDER BY 1",
          "format": "time_series",
          "maxDataPoints": 300
        },
        {
          "refId": "B",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, (val->>'tx_mbps')::numeric * 1000000 AS \"Upload (bps)\"\nFROM public.machine_telemetry,\nLATERAL jsonb_each(interface_metrics) AS iface(key, val)\nWHERE $__timeFilter(time)\n  AND machine_id IN (${machine_id:sqlstring})\n  AND iface.key IN (${interface:sqlstring})\nORDER BY 1",
          "format": "time_series",
          "maxDataPoints": 300
        }
      ],
      "description": "Per-interface bandwidth from interface_metrics JSONB. Download positive, Upload mirrored via negative-Y axis.",
      "transparent": true,
      "links": [
        {
          "title": "Drill-down → Engineering",
          "url": "/d/ims-engineering?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ]
    },
