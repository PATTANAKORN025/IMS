{
  "uid": "ims-engineering",
  "title": "IMS Engineering Drill-Down",
  "tags": [
    "ims",
    "engineering"
  ],
  "timezone": "Asia/Bangkok",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "links": [
    {
      "title": "TV Kiosk Mode",
      "url": "/d/ims-engineering?orgId=1&kiosk=tv",
      "type": "link",
      "icon": "bolt",
      "targetBlank": true
    },
    {
      "title": "NOC Overview",
      "url": "/d/ims-noc-overview",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    },
    {
      "title": "AIOps & Capacity",
      "url": "/d/ims-capacity",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT machine_id FROM public.machine_telemetry ORDER BY machine_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "label": "Machine"
      },
      {
        "name": "interface",
        "type": "query",
        "query": "SELECT DISTINCT key FROM (SELECT interface_metrics FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '10 minutes' ORDER BY time DESC LIMIT 100) AS recent, jsonb_object_keys(recent.interface_metrics) AS key ORDER BY key",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Interface"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 0,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 2,
        "w": 20,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "html",
        "content": "<style>\n@import url(\"https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;700&display=swap\");\n.dashboard-page { background: #05050A !important; font-family: \"Rajdhani\", sans-serif !important; }\n.panel-container { background: rgba(12,16,26,0.8) !important; border: 1px solid rgba(0,242,254,0.15) !important; border-radius: 4px !important; backdrop-filter: blur(4px) !important; box-shadow: inset 0 1px 10px rgba(0,242,254,0.02) !important; transition: border-color 0.3s ease, transform 0.3s ease; }\n.panel-container:hover { border-color: rgba(0,242,254,0.6) !important; transform: translateY(-2px); }\n.panel-title { color: #A0B0C0 !important; font-size: 14px !important; font-weight: 700 !important; letter-spacing: 1px; }\n</style>\n<div class=\"apex-banner\" style=\"display:flex;justify-content:space-between;align-items:center;height:100%;padding:0 20px;background:linear-gradient(90deg,rgba(0,242,254,0.1) 0%,transparent 100%);border-left:4px solid #00F2FE;border-radius:4px;box-sizing:border-box;\">\n  <h1 style=\"font-size:20px;font-weight:800;color:#fff;letter-spacing:3px;text-shadow:0 0 10px #00F2FE;margin:0;\">APEX <span style=\"color:#00F2FE;\">COMMAND</span> <span style=\"color:#8899aa;font-size:14px;letter-spacing:1px;\">// IMS Engineering</span></h1>\n  <div class=\"apex-nav\" style=\"display:flex;gap:20px;\">\n    <a href=\"/d/ims-noc-overview\" style=\"color:#8899aa;text-decoration:none;font-size:14px;font-weight:700;padding:4px 12px;border:1px solid transparent;transition:all 0.2s;\">NOC</a>\n    <a href=\"/d/ims-engineering\" class=\"active\" style=\"color:#8899aa;text-decoration:none;font-size:14px;font-weight:700;padding:4px 12px;border:1px solid transparent;transition:all 0.2s;\">ENG</a>\n    <a href=\"/d/ims-capacity\" style=\"color:#8899aa;text-decoration:none;font-size:14px;font-weight:700;padding:4px 12px;border:1px solid transparent;transition:all 0.2s;\">CAP</a>\n  </div>\n</div>"
      },
      "datasource": null,
      "transparent": true,
      "description": "OS Taskbar navigation and CSS theme."
    },
    {
      "id": 1001,
