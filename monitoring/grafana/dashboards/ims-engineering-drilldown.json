    {
      "id": 1,
      "title": "CPU Load",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 7
      },
      "transparent": true,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT cpu_load_percent AS value FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '2 minutes' AND machine_id IN (${machine_id:sqlstring}) ORDER BY time DESC LIMIT 1",
          "format": "table"
        }
      ],
      "links": [
        {
          "title": "Capacity forecast →",
          "url": "/d/ims-capacity?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        },
        {
          "title": "Drill-down → Engineering",
          "url": "/d/ims-engineering?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Current CPU utilization (%) for the selected machine. Yellow >80%, Red >90%."
    },
    {
      "id": 2,
      "title": "RAM Usage",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 7
      },
      "transparent": true,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 85
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT ROUND((ram_used_mb / NULLIF(ram_total_mb, 0) * 100)::NUMERIC, 1) AS value FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '2 minutes' AND machine_id IN (${machine_id:sqlstring}) ORDER BY time DESC LIMIT 1",
          "format": "table"
        }
      ],
      "links": [
        {
          "title": "Capacity forecast →",
          "url": "/d/ims-capacity?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        },
        {
          "title": "Drill-down → Engineering",
          "url": "/d/ims-engineering?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Current RAM utilization (%) for the selected machine. Yellow >85%, Red >95%."
    },
    {
      "id": 3,
      "title": "Storage Saturation",
      "type": "gauge",
      "datasource": {
