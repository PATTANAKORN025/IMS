        "mode": "html",
        "content": "<style>\n@import url(\"https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap\");\n.dashboard-page {\n  background: radial-gradient(circle at center, #0B0E14 0%, #040508 100%),\n    linear-gradient(0deg,transparent 24%,rgba(0,242,254,0.03) 25%,rgba(0,242,254,0.03) 26%,transparent 27%),\n    linear-gradient(90deg,transparent 24%,rgba(0,242,254,0.03) 25%,rgba(0,242,254,0.03) 26%,transparent 27%) !important;\n  background-size: 100% 100%,50px 50px,50px 50px !important;\n  font-family:'Rajdhani',sans-serif !important;\n}\n.panel-container {\n  position: relative;\n  background: linear-gradient(135deg,rgba(16,20,30,0.95) 0%,rgba(10,12,20,0.98) 100%) !important;\n  border: 1px solid rgba(0,242,254,0.4) !important;\n  box-shadow: 0 0 10px rgba(0,242,254,0.1) !important;\n  border-radius: 2px !important;\n}\n.panel-container::before {\n  content: \"\";\n  position: absolute;\n  top: 0; left: 0; right: 0; height: 2px;\n  background: #00F2FE;\n}\n.panel-title { font-size: 16px !important; color: #E0E0E0 !important; text-transform: uppercase; }\n.react-grid-item { padding: 2px !important; margin: 0 !important; }\n.row-container { background: rgba(0,242,254,0.04) !important; border-left: 3px solid #00F2FE !important; }\n</style><div style=\"display:flex;justify-content:space-between;align-items:center;height:100%;border-bottom:2px solid #00F2FE;padding:0 16px;\"><div style=\"font-size:26px;font-weight:700;color:#fff;letter-spacing:4px;font-family:Rajdhani,sans-serif;\">ENGINEERING DRILL-DOWN</div><div style=\"color:#00FF87;font-size:12px;\">PER-MACHINE DIAGNOSTICS</div></div>"
      },
