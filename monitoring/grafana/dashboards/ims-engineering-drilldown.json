      "options": {
        "mode": "html",
        "content": "<div style=\"font-family:Rajdhani,monospace; padding:8px; background:rgba(0,0,0,0.3); border-radius:12px; border:1px solid rgba(0,242,254,0.15);\">\n<div style=\"text-align:center; color:#00F2FE; font-size:13px; letter-spacing:3px; margin-bottom:8px; text-shadow:0 0 8px rgba(0,242,254,0.5);\">SYSTEM MATRIX ANALYSIS</div>\n<svg viewBox=\"0 0 300 280\" style=\"width:100%; max-height:240px;\">\n  <defs>\n    <filter id=\"glow\"><feGaussianBlur stdDeviation=\"2\" result=\"blur\"/><feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>\n    <linearGradient id=\"radarFill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stop-color=\"rgba(0,255,135,0.25)\"/>\n      <stop offset=\"100%\" stop-color=\"rgba(0,255,135,0.05)\"/>\n    </linearGradient>\n  </defs>\n  <!-- Radar grid (5 concentric polygons) -->\n  <g transform=\"translate(150,140)\" filter=\"url(#glow)\">\n    <polygon points=\"0,-110 95,-55 95,55 0,110 -95,55 -95,-55\" fill=\"none\" stroke=\"rgba(0,242,254,0.08)\" stroke-width=\"1\"/>\n    <polygon points=\"0,-88 76,-44 76,44 0,88 -76,44 -76,-44\" fill=\"none\" stroke=\"rgba(0,242,254,0.12)\" stroke-width=\"1\"/>\n    <polygon points=\"0,-66 57,-33 57,33 0,66 -57,33 -57,-33\" fill=\"none\" stroke=\"rgba(0,242,254,0.16)\" stroke-width=\"1\"/>\n    <polygon points=\"0,-44 38,-22 38,22 0,44 -38,22 -38,-22\" fill=\"none\" stroke=\"rgba(0,242,254,0.20)\" stroke-width=\"1\"/>\n    <polygon points=\"0,-22 19,-11 19,11 0,22 -19,11 -19,-11\" fill=\"none\" stroke=\"rgba(0,242,254,0.25)\" stroke-width=\"1\"/>\n    <!-- Axis lines -->\n    <line x1=\"0\" y1=\"0\" x2=\"0\" y2=\"-110\" stroke=\"rgba(0,242,254,0.15)\" stroke-width=\"1\"/>\n    <line x1=\"0\" y1=\"0\" x2=\"95\" y2=\"-55\" stroke=\"rgba(0,242,254,0.15)\" stroke-width=\"1\"/>\n    <line x1=\"0\" y1=\"0\" x2=\"95\" y2=\"55\" stroke=\"rgba(0,242,254,0.15)\" stroke-width=\"1\"/>\n    <line x1=\"0\" y1=\"0\" x2=\"0\" y2=\"110\" stroke=\"rgba(0,242,254,0.15)\" stroke-width=\"1\"/>\n    <line x1=\"0\" y1=\"0\" x2=\"-95\" y2=\"55\" stroke=\"rgba(0,242,254,0.15)\" stroke-width=\"1\"/>\n    <line x1=\"0\" y1=\"0\" x2=\"-95\" y2=\"-55\" stroke=\"rgba(0,242,254,0.15)\" stroke-width=\"1\"/>\n    <!-- Data polygon -->\n    <polygon points=\"0,-93.5 76,-44 57,33 0,88 -57,22 -76,-33\" fill=\"url(#radarFill)\" stroke=\"#00FF87\" stroke-width=\"2\" filter=\"url(#glow)\"/>\n    <!-- Data points -->\n    <circle cx=\"0\" cy=\"-93.5\" r=\"4\" fill=\"#00FF87\" filter=\"url(#glow)\"/>\n    <circle cx=\"76\" cy=\"-44\" r=\"4\" fill=\"#00F2FE\" filter=\"url(#glow)\"/>\n    <circle cx=\"57\" cy=\"33\" r=\"4\" fill=\"#7F00FF\" filter=\"url(#glow)\"/>\n    <circle cx=\"0\" cy=\"88\" r=\"4\" fill=\"#FF9100\" filter=\"url(#glow)\"/>\n    <circle cx=\"-57\" cy=\"22\" r=\"4\" fill=\"#00E5FF\" filter=\"url(#glow)\"/>\n    <circle cx=\"-76\" cy=\"-33\" r=\"4\" fill=\"#FF007F\" filter=\"url(#glow)\"/>\n  </g>\n  <!-- Labels -->\n  <text x=\"150\" y=\"22\" text-anchor=\"middle\" fill=\"#00F2FE\" font-size=\"10\" font-family=\"Rajdhani,monospace\" font-weight=\"700\">CPU Load</text>\n  <text x=\"262\" y=\"82\" text-anchor=\"start\" fill=\"#00F2FE\" font-size=\"10\" font-family=\"Rajdhani,monospace\" font-weight=\"700\">Memory</text>\n  <text x=\"262\" y=\"202\" text-anchor=\"start\" fill=\"#00F2FE\" font-size=\"10\" font-family=\"Rajdhani,monospace\" font-weight=\"700\">Storage</text>\n  <text x=\"150\" y=\"268\" text-anchor=\"middle\" fill=\"#00F2FE\" font-size=\"10\" font-family=\"Rajdhani,monospace\" font-weight=\"700\">Thermal</text>\n  <text x=\"38\" y=\"202\" text-anchor=\"end\" fill=\"#00F2FE\" font-size=\"10\" font-family=\"Rajdhani,monospace\" font-weight=\"700\">Net RX</text>\n  <text x=\"38\" y=\"82\" text-anchor=\"end\" fill=\"#00F2FE\" font-size=\"10\" font-family=\"Rajdhani,monospace\" font-weight=\"700\">Net TX</text>\n</svg>\n</div>"
      },
