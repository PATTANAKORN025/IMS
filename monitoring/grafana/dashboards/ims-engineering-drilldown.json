          "legendFormat": "Z-Score (Anomaly)",
          "rawSql": "WITH stats AS (SELECT bucket, max_temp, AVG(max_temp) OVER w AS mu, COALESCE(STDDEV(max_temp) OVER w, 0) AS sigma FROM public.telemetry_minute_summary WHERE machine_id = '${machine_id}' AND max_temp > 0 AND $__timeFilter(bucket) WINDOW w AS (PARTITION BY machine_id ORDER BY bucket ROWS BETWEEN 60 PRECEDING AND 1 PRECEDING)) SELECT bucket AS time, CASE WHEN sigma > 0 THEN ROUND(((max_temp - mu) / sigma)::NUMERIC, 2) ELSE 0 END AS \"Z-Score\" FROM stats ORDER BY 1",
          "format": "time_series"
        }
