          "url": "/d/ims-engineering?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
        }
      ],
      "description": "Current RAM utilization (%) for the selected machine. Yellow >85%, Red >95%."
    },
