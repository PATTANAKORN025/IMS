    {
      "id": 40,
      "title": "CPU Anomaly Score (Z-Score)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 37
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": 60000,
            "thresholdsStyle": {
              "mode": "dashed"
            },
            "gradientMode": "opacity",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": -3
              },
              {
                "color": "transparent",
                "value": -2
              },
              {
                "color": "green",
                "value": -1
              },
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "transparent",
                "value": 2
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(?!.*TX|Upload|Z-Score).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#00FF87"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH stats AS (SELECT bucket, avg_cpu_load, AVG(avg_cpu_load) OVER w AS moving_avg, COALESCE(STDDEV(avg_cpu_load) OVER w, 0) AS moving_stddev FROM public.telemetry_minute_summary WHERE machine_id = '${machine_id}' AND $__timeFilter(bucket) WINDOW w AS (PARTITION BY machine_id ORDER BY bucket ROWS BETWEEN 60 PRECEDING AND 1 PRECEDING)) SELECT bucket AS time, CASE WHEN moving_stddev > 0 THEN ROUND(((avg_cpu_load - moving_avg) / moving_stddev)::NUMERIC, 2) ELSE 0 END AS \"Z-Score\" FROM stats ORDER BY 1",
          "format": "time_series",
          "maxDataPoints": 300
        }
      ],
      "description": "CPU Z-Score computed using 60-minute rolling window. Values beyond ±3σ indicate anomalies."
    },
