    {
      "id": 300,
      "type": "row",
      "title": "Network & Environment",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false
    },
    {
      "id": 502,
      "title": "Ethernet/WiFi Bandwidth (Per-Interface)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": 60000,
            "gradientMode": "opacity",
            "drawStyle": "line"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "eth0 RX (bps)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#1F60C4",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "eth0 TX (bps)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#5794F2",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "wlan0 RX (bps)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8E24AA",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "wlan0 TX (bps)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#E02F44",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Upload.*"
            },
            "properties": [
              {
                "id": "custom.transform",
                "value": "negative-Y"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*TX|Upload|Upload.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF007F"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, (val->>'rx_mbps')::numeric * 1000000 AS \"Download (bps)\"\nFROM public.machine_telemetry,\nLATERAL jsonb_each(interface_metrics) AS iface(key, val)\nWHERE $__timeFilter(time)\n  AND machine_id = '${machine_id}'\n  AND iface.key IN (${interface:sqlstring})\nORDER BY 1",
          "format": "time_series",
          "maxDataPoints": 300
        },
        {
          "refId": "B",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, (val->>'tx_mbps')::numeric * 1000000 AS \"Upload (bps)\"\nFROM public.machine_telemetry,\nLATERAL jsonb_each(interface_metrics) AS iface(key, val)\nWHERE $__timeFilter(time)\n  AND machine_id = '${machine_id}'\n  AND iface.key IN (${interface:sqlstring})\nORDER BY 1",
          "format": "time_series",
          "maxDataPoints": 300
        }
      ],
      "description": "Per-interface bandwidth from interface_metrics JSONB. Download positive, Upload mirrored via negative-Y axis."
    },
    {
