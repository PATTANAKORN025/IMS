          "rawSql": "SELECT 'Errors' AS metric, SUM((value->>'errors')::NUMERIC) AS value FROM public.machine_telemetry, jsonb_each(interface_metrics) WHERE machine_id = '${machine_id}' AND $__timeFilter(time) AND key = ANY(ARRAY[${interface:sqlstring}]::text[]) AND value ? 'errors' UNION ALL SELECT 'Drops' AS metric, SUM((value->>'drops')::NUMERIC) AS value FROM public.machine_telemetry, jsonb_each(interface_metrics) WHERE machine_id = '${machine_id}' AND $__timeFilter(time) AND key = ANY(ARRAY[${interface:sqlstring}]::text[]) AND value ? 'drops'",
