        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "html",
        "content": "<style>\n@import url(\"https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap\");\n* { box-sizing: border-box; }\n.dashboard-page {\n  background: radial-gradient(circle at center,#0B0E14 0%,#040508 100%),\n    linear-gradient(0deg,transparent 24%,rgba(0,242,254,.03) 25%,rgba(0,242,254,.03) 26%,transparent 27%),\n    linear-gradient(90deg,transparent 24%,rgba(0,242,254,.03) 25%,rgba(0,242,254,.03) 26%,transparent 27%) !important;\n  background-size: 100% 100%,50px 50px,50px 50px !important;\n  font-family:'Rajdhani',sans-serif !important;\n}\n.panel-container {\n  position: relative;\n  background: linear-gradient(135deg,rgba(16,20,30,.95) 0%,rgba(10,12,20,.98) 100%);\n  border: 1px solid rgba(0,242,254,.2);\n  box-shadow: 0 0 10px rgba(0,242,254,.05);\n  border-radius: 2px;\n  padding: 8px;\n}\n.panel-container::before {\n  content: \"\"; position: absolute; top: 0; left: 0; right: 0; height: 2px;\n  background: #00F2FE;\n}\n.panel-title { font-size: 12px; color: #B0B0B0; text-transform: uppercase; letter-spacing: 1px; }\n</style><div style=\"display:flex;align-items:center;gap:20px;height:100%;padding:0 16px;\n  border-bottom:2px solid #00F2FE;background:linear-gradient(90deg,rgba(0,242,254,.08),transparent);\">\n  <div style=\"font-size:24px;font-weight:700;color:#fff;text-shadow:0 0 12px #00F2FE;letter-spacing:4px;\n    font-family:Rajdhani,sans-serif;white-space:nowrap;\">APEX <span style=\"color:#00F2FE\">COMMAND</span></div>\n  <div style=\"flex:1\"></div>\n  <span style=\"color:#00FF87;font-size:11px;text-shadow:0 0 4px #00FF87;letter-spacing:1px;\">SYSTEM ONLINE</span>\n  <span style=\"color:#889;font-size:11px;letter-spacing:1px;padding:0 8px;\">|</span>\n  <a href=\"/d/ims-noc-overview\" target=\"_blank\" style=\"color:#00F2FE;font-size:11px;text-decoration:none;letter-spacing:1px;font-weight:700;\">NOC</a>\n  <a href=\"/d/ims-engineering\" target=\"_blank\" style=\"color:#00FF87;font-size:11px;text-decoration:none;letter-spacing:1px;font-weight:700;\">ENG</a>\n  <a href=\"/d/ims-capacity\" target=\"_blank\" style=\"color:#7F00FF;font-size:11px;text-decoration:none;letter-spacing:1px;font-weight:700;\">CAP</a>\n</div>"
      },
      "datasource": null,
      "transparent": true,
      "description": "Unified command banner with navigation."
    },
    {
