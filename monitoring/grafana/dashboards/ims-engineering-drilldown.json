        "noValue": "N/A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT ROUND((disk_used_gb / NULLIF(disk_total_gb, 0) * 100)::NUMERIC, 1) AS value FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '2 minutes' AND machine_id IN (${machine_id:sqlstring}) ORDER BY time DESC LIMIT 1",
          "format": "table"
        }
      ],
      "links": [
        {
          "title": "Capacity forecast →",
          "url": "/d/ims-capacity?var-machine_id=${machine_id}&from=${__from}&to=${__to}",
          "targetBlank": true
