{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Pipeline Health",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Inserts / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(ims_pipeline_inserts_total[5m])",
          "legendFormat": "Inserts/sec",
          "refId": "A"
        }
      ],
      "description": "Rate of successful database inserts per second from the pipeline."
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "fixedColor": "#EF444D",
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(ims_pipeline_inserts_failed_total[5m])",
          "legendFormat": "Errors/sec",
          "refId": "A"
        }
      ],
      "description": "Rate of failed database inserts per second. High values indicate pipeline instability."
    },
    {
      "type": "stat",
      "title": "Last Flush",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#EF444D",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 120
              },
              {
                "color": "#10B981",
                "value": 300
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "custom.fontFamily",
                "value": "'Roboto Mono', monospace"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "ims_pipeline_last_flush_timestamp_seconds * 1000",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "description": "Timestamp of the most recent successful batch flush to TimescaleDB.",
      "options": {
        "noValue": "No data"
      }
    },
