    {
      "type": "row",
      "title": "Circuit Breaker Trips",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      }
    },
    {
      "type": "timeseries",
      "title": "Trip Rate (per device)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(ims_circuit_breaker_trips_total[5m])",
          "legendFormat": "{{device_id}}",
          "refId": "A"
        }
      ],
      "description": "Rate of circuit breaker trips per device. Indicates intermittent connectivity issues."
    },
    {
      "type": "table",
      "title": "Device Circuit Breaker State",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "device_id"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "CLOSED",
                        "color": "#10B981"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "OPEN",
                        "color": "#EF444D"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "2": {
                        "text": "HALF-OPEN",
                        "color": "#3B82F6"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "custom.fontFamily",
                "value": "'Roboto Mono', monospace"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "ims_circuit_breaker_state",
          "legendFormat": "{{device_id}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "device_id": "Device",
              "Value": "State"
            }
          }
        }
      ],
      "description": "Per-device circuit breaker state table (0=CLOSED, 1=OPEN, 2=HALF_OPEN)."
    },
