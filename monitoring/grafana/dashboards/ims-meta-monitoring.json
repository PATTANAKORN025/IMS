    {
      "type": "timeseries",
      "title": "Devices Polled / cycle",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
