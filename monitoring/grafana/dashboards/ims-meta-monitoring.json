    },
    {
      "type": "gauge",
      "title": "Pipeline Success Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#EF444D",
                "value": null
              },
              {
                "color": "#F59E0B",
                "value": 0.95
              },
              {
                "color": "#10B981",
                "value": 0.99
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "/.*/"
            },
            "properties": [
              {
                "id": "custom.fontFamily",
                "value": "'Roboto Mono', monospace"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(ims_pipeline_inserts_total[5m]) / (rate(ims_pipeline_inserts_total[5m]) + rate(ims_pipeline_inserts_failed_total[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "description": "Ratio of successful inserts to total inserts (success / (success + failure)).",
      "options": {
        "noValue": "N/A"
      }
