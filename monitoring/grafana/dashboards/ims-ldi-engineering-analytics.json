{
  "uid": "ldi-engineering-analytics",
  "title": "IMS LDI — Engineering Analytics & SPC",
  "description": "Layer 3 Process Timeline: synchronized multi-parameter RCA. temperature → humidity → scan_speed → air_vacuum → scale_x/y → pe_1~6 → je_1~4 → state. Shared crosshair + tooltip. Fixed axis scaling.",
  "tags": [
    "ims",
    "ldi",
    "engineering",
    "spc",
    "analytics",
    "rca"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "liveNow": true,
  "style": "dark",
  "graphTooltip": 2,
  "templating": {
    "list": [
      {
        "name": "factory",
        "type": "query",
        "query": "SELECT DISTINCT factory FROM public.ldi_data ORDER BY factory",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Factory"
      },
      {
        "name": "mo",
        "type": "query",
        "query": "SELECT DISTINCT mo FROM public.ldi_data WHERE factory IN ($factory) ORDER BY mo",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "MO (Work Order)"
      },
      {
        "name": "process",
        "type": "custom",
        "query": "DF INNER,DF OUTER,SM",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "label": "Process"
      },
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT eqp_id AS __text, eqp_id AS __value FROM public.ldi_data ORDER BY eqp_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Machine"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "temperature (°C)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "palette-classic"
          },
          "min": 18,
          "max": 28,
          "links": [
            {
              "title": "Incident Snapshot (by log_id)",
              "url": "/d/ldi-machine-snapshot/ims-ldi-machine-snapshot?var-machine_id=${__series.name}&var-log_id=${__data.fields.log_id}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('1 minute', time) AS time, eqp_id AS metric, AVG(temperature)::NUMERIC AS value FROM public.ldi_data WHERE factory IN ($factory) AND $__timeFilter(time) AND process IN ($process) AND eqp_id IN (${machine_id:singlequote}) AND temperature IS NOT NULL GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "temperature per machine. Fixed axis 18-28°C (target 22±2°C). Shared crosshair syncs with all panels below."
    },
