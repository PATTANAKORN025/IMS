    {
      "id": 9,
      "title": "state",
      "type": "state-timeline",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 24,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "RUNNING",
                  "color": "#22C55E"
                },
                "0": {
                  "text": "DOWN",
                  "color": "#EF4444"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#22C55E",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "center",
        "rowHeight": 0.85,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id AS metric, CASE WHEN state THEN 1 ELSE 0 END AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "transparent": true,
      "description": "Machine lifesign: GREEN = RUNNING (state=true), RED = DOWN (state=false). Full-width panel for instant visibility of machine availability."
    },
    {
      "id": 10,
      "title": "v_machine_spc_ranking",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 8
      },
      "options": {
        "showHeader": true,
        "rowHeight": 0.65,
        "sortBy": [
          {
            "displayName": "Cpk",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT eqp_id AS \"Machine\", sample_count AS \"Samples\", mean_pe AS \"Mean PE\", stddev_pe AS \"StdDev\", cp AS \"Cp\", cpk AS \"Cpk\", capability_class AS \"Capability\" FROM public.v_machine_spc_ranking ORDER BY cpk DESC",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Machine ranking by Cpk (process capability index). World Class >= 2.0, Excellent >= 1.67, Capable >= 1.33, Marginal >= 1.0, Not Capable < 1.0.",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Capability"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "World Class": {
                        "color": "#22C55E",
                        "text": "World Class"
                      },
                      "Excellent": {
                        "color": "#22C55E",
                        "text": "Excellent"
                      },
                      "Capable": {
                        "color": "#FACC15",
                        "text": "Capable"
                      },
                      "Marginally Capable": {
                        "color": "#FACC15",
                        "text": "Marginal"
                      },
                      "Not Capable": {
                        "color": "#EF4444",
                        "text": "Not Capable"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      }
    },
