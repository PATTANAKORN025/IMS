{
  "uid": "ldi-engineering-analytics",
  "title": "IMS LDI — Engineering Analytics & SPC",
  "description": "Process engineer view. SPC control charts, XY correlation, Z-Score anomaly. Requires $machine_id variable.",
  "tags": [
    "ims",
    "ldi",
    "engineering",
    "spc",
    "analytics"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "liveNow": true,
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT eqp_id AS __text, eqp_id AS __value FROM public.ldi_data ORDER BY eqp_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "label": "Machine"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "X-Bar Control Chart — Max PE Deviation",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthum",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('1 minute', time) AS time, eqp_id AS metric, ROUND(AVG(GREATEST(ABS(COALESCE(pe_1,0)),ABS(COALESCE(pe_2,0)),ABS(COALESCE(pe_3,0)),ABS(COALESCE(pe_4,0)),ABS(COALESCE(pe_5,0)),ABS(COALESCE(pe_6,0))))::NUMERIC, 2) AS \"X-Bar\" FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND pe_1 IS NOT NULL GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series",
          "legendFormat": "{{metric}} X-Bar"
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH raw_pe AS (SELECT time_bucket('1 minute', time) AS time, eqp_id, AVG(GREATEST(ABS(COALESCE(pe_1,0)),ABS(COALESCE(pe_2,0)),ABS(COALESCE(pe_3,0)),ABS(COALESCE(pe_4,0)),ABS(COALESCE(pe_5,0)),ABS(COALESCE(pe_6,0)))) AS max_pe FROM public.ldi_data WHERE pe_1 IS NOT NULL GROUP BY 1, 2) SELECT time, eqp_id AS metric, ROUND((AVG(max_pe) OVER (PARTITION BY eqp_id ORDER BY time ROWS BETWEEN 29 PRECEDING AND CURRENT ROW) + 3 * COALESCE(STDDEV(max_pe) OVER (PARTITION BY eqp_id ORDER BY time ROWS BETWEEN 29 PRECEDING AND CURRENT ROW), 0))::NUMERIC, 2) AS \"UCL\" FROM raw_pe WHERE eqp_id IN (${machine_id:singlequote}) ORDER BY time",
          "format": "time_series",
          "legendFormat": "{{metric}} UCL"
        },
        {
          "refId": "C",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH raw_pe AS (SELECT time_bucket('1 minute', time) AS time, eqp_id, AVG(GREATEST(ABS(COALESCE(pe_1,0)),ABS(COALESCE(pe_2,0)),ABS(COALESCE(pe_3,0)),ABS(COALESCE(pe_4,0)),ABS(COALESCE(pe_5,0)),ABS(COALESCE(pe_6,0)))) AS max_pe FROM public.ldi_data WHERE pe_1 IS NOT NULL GROUP BY 1, 2) SELECT time, eqp_id AS metric, ROUND(AVG(max_pe) OVER (PARTITION BY eqp_id ORDER BY time ROWS BETWEEN 29 PRECEDING AND CURRENT ROW)::NUMERIC, 2) AS \"CL (μ)\" FROM raw_pe WHERE eqp_id IN (${machine_id:singlequote}) ORDER BY time",
          "format": "time_series",
          "legendFormat": "{{metric}} CL"
        },
        {
          "refId": "D",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH raw_pe AS (SELECT time_bucket('1 minute', time) AS time, eqp_id, AVG(GREATEST(ABS(COALESCE(pe_1,0)),ABS(COALESCE(pe_2,0)),ABS(COALESCE(pe_3,0)),ABS(COALESCE(pe_4,0)),ABS(COALESCE(pe_5,0)),ABS(COALESCE(pe_6,0)))) AS max_pe FROM public.ldi_data WHERE pe_1 IS NOT NULL GROUP BY 1, 2) SELECT time, eqp_id AS metric, ROUND((AVG(max_pe) OVER (PARTITION BY eqp_id ORDER BY time ROWS BETWEEN 29 PRECEDING AND CURRENT ROW) - 3 * COALESCE(STDDEV(max_pe) OVER (PARTITION BY eqp_id ORDER BY time ROWS BETWEEN 29 PRECEDING AND CURRENT ROW), 0))::NUMERIC, 2) AS \"LCL\" FROM raw_pe WHERE eqp_id IN (${machine_id:singlequote}) ORDER BY time",
          "format": "time_series",
          "legendFormat": "{{metric}} LCL"
        }
      ],
      "description": "Max absolute PE deviation across 6 measurement points. Green < 15µm, Amber 15-25µm, Red > 25µm (breach). Horizontal threshold lines at 15µm and 25µm.",
      "transparent": true
    },
    {
      "id": 2,
      "title": "Registration Error Distribution vs Spec Limits",
      "type": "histogram",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthum",
          "custom": {
            "fillOpacity": 60,
            "lineWidth": 1
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#22C55E",
                "value": null
              },
              {
                "color": "#FACC15",
                "value": 20
              },
              {
                "color": "#EF4444",
                "value": 25
              }
            ]
          },
          "thresholdsStyle": {
            "mode": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "bucketSize": 2,
        "combine": true,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT GREATEST(ABS(COALESCE(pe_1,0)),ABS(COALESCE(pe_2,0)),ABS(COALESCE(pe_3,0)),ABS(COALESCE(pe_4,0)),ABS(COALESCE(pe_5,0)),ABS(COALESCE(pe_6,0)))::NUMERIC AS \"PE Deviation\" FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND pe_1 IS NOT NULL",
          "format": "time_series"
        }
      ],
      "description": [
        "Histogram of max PE deviation across all 6 fiducials. Shows process centering and spread relative to ±25µm spec limits."
      ],
      "transparent": true
    },
    {
      "id": 3,
      "title": "Correlation: Temperature vs Registration Error",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthum",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Temp.*"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "left"
              },
              {
                "id": "custom.axisLabel",
                "value": "Temperature (C)"
              },
              {
                "id": "unit",
                "value": "celsius"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*PE.*"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.axisLabel",
                "value": "PE Deviation (um)"
              },
              {
                "id": "unit",
                "value": "lengthum"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id || ' - Temperature' AS metric, temperature AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND temperature IS NOT NULL ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id || ' - Max PE' AS metric, ROUND(GREATEST(ABS(COALESCE(pe_1,0)),ABS(COALESCE(pe_2,0)),ABS(COALESCE(pe_3,0)),ABS(COALESCE(pe_4,0)),ABS(COALESCE(pe_5,0)),ABS(COALESCE(pe_6,0)))::NUMERIC, 2) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND pe_1 IS NOT NULL ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "description": [
        "XY Scatter: Temperature (X-axis) vs Max PE Deviation (Y-axis). Shows whether thermal drift correlates with alignment error."
      ],
      "transparent": true
    },
    {
      "id": 4,
      "title": "Humidity vs Registration Error",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*PE.*"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.axisLabel",
                "value": "PE (µm)"
              },
              {
                "id": "unit",
                "value": "lengthum"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Hum.*"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "left"
              },
              {
                "id": "custom.axisLabel",
                "value": "Humidity (%)"
              },
              {
                "id": "unit",
                "value": "humidity"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id || ' - Humidity' AS metric, humidity AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND humidity IS NOT NULL ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, eqp_id || ' - Max PE' AS metric, ROUND(GREATEST(ABS(pe_1), ABS(pe_2), ABS(pe_3), ABS(pe_4), ABS(pe_5), ABS(pe_6))::NUMERIC, 1) AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote}) AND pe_1 IS NOT NULL ORDER BY time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "description": "Dual Y-axis: Humidity (line, left) vs Max PE Deviation (line, right). Humidity-induced dimensional expansion skews registration.",
      "transparent": true
    },
    {
      "id": 5,
      "title": "Thermal Z-Score Anomaly (3σ)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#22C55E",
                "value": -2
              },
              {
                "color": "#FACC15",
                "value": 2.5
              },
              {
                "color": "#EF4444",
                "value": 3
              }
            ]
          },
          "thresholdsStyle": {
            "mode": "line+area"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH stats AS (SELECT eqp_id, AVG(temperature) AS mu, STDDEV(temperature) AS sigma FROM public.ldi_data WHERE time > NOW() - INTERVAL '24 hours' AND eqp_id IN (${machine_id:singlequote}) GROUP BY eqp_id) SELECT d.time, d.eqp_id AS metric, ROUND(((d.temperature - s.mu) / NULLIF(s.sigma, 0))::NUMERIC, 2) AS \"Z-Score\" FROM public.ldi_data d JOIN stats s ON d.eqp_id = s.eqp_id WHERE d.time >= (SELECT $__timeFrom) AND d.time <= (SELECT $__timeTo) AND d.eqp_id IN (${machine_id:singlequote}) AND d.temperature IS NOT NULL ORDER BY d.time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "description": "3-sigma Z-Score. Green: -2 to +2 (normal). Amber: 2.5 (watch). Red: 3+ (anomaly).",
      "transparent": true
    },
    {
      "id": 6,
      "title": "PE Alignment Z-Score (3σ)",
      "type": "timeseries",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "gradientMode": "opacity",
            "connectNullPoints": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#22C55E",
                "value": -2
              },
              {
                "color": "#FACC15",
                "value": 2.5
              },
              {
                "color": "#EF4444",
                "value": 3
              }
            ]
          },
          "thresholdsStyle": {
            "mode": "line+area"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "connectNullPoints": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "WITH base AS (SELECT time, eqp_id, GREATEST(ABS(pe_1), ABS(pe_2), ABS(pe_3), ABS(pe_4), ABS(pe_5), ABS(pe_6)) AS max_pe FROM public.ldi_data WHERE time > NOW() - INTERVAL '24 hours' AND eqp_id IN (${machine_id:singlequote}) AND pe_1 IS NOT NULL), stats AS (SELECT eqp_id, AVG(max_pe) AS mu, STDDEV(max_pe) AS sigma FROM base GROUP BY eqp_id) SELECT b.time, b.eqp_id AS metric, ROUND(((b.max_pe - s.mu) / NULLIF(s.sigma, 0))::NUMERIC, 2) AS \"PE Z-Score\" FROM base b JOIN stats s ON b.eqp_id = s.eqp_id WHERE s.sigma > 0 ORDER BY b.time ASC",
          "format": "time_series",
          "legendFormat": "{{metric}}"
        }
      ],
      "description": "Z-Score of max PE deviation. Tracks if alignment error is statistically drifting beyond normal process variation.",
      "transparent": true
    },
    {
      "id": 7,
      "title": "Machine Cpk Ranking",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Cpk",
            "desc": true
          }
        ],
        "rowHeight": 0.7
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT eqp_id AS \"Machine\", sample_count AS \"Samples\", mean_pe AS \"Mean PE\", stddev_pe AS \"StdDev\", cp AS \"Cp\", cpk AS \"Cpk\", capability_class AS \"Capability\" FROM public.v_machine_spc_ranking ORDER BY cpk DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Capability"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "World Class": {
                        "color": "#22C55E",
                        "text": "World Class"
                      },
                      "Excellent": {
                        "color": "#22C55E",
                        "text": "Excellent"
                      },
                      "Capable": {
                        "color": "#FACC15",
                        "text": "Capable"
                      },
                      "Marginally Capable": {
                        "color": "#FACC15",
                        "text": "Marginal"
                      },
                      "Not Capable": {
                        "color": "#EF4444",
                        "text": "Not Capable"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "description": "Machine ranking by Cpk (process capability index). Cpk >= 1.67 = Excellent, >= 1.33 = Capable, < 1.0 = Not Capable.",
      "transparent": true
    },
    {
      "id": 8,
      "title": "Process Stability Index",
      "type": "bargauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#FACC15",
                "value": 40
              },
              {
                "color": "#22C55E",
                "value": 70
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT eqp_id AS metric, stability_index AS value FROM public.v_process_stability ORDER BY stability_index DESC",
          "format": "table"
        }
      ],
      "description": "Composite stability score (0-100) combining temperature, humidity, and PE stability. Green >= 70, Amber >= 40, Red < 40.",
      "transparent": true
    }
  ],
  "fiscalYearStartMonth": 0
}