    {
      "id": 10,
      "title": "Alarm Context (±5 min of clicked timestamp)",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 4
      },
      "options": {
        "showHeader": true,
        "rowHeight": 0.6,
        "sortBy": [
          {
            "displayName": "Time",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT al.logdate AS \"Time\", al.equipmentid AS \"Machine\", al.errorcode AS \"Code\", al.errortime AS \"Error Time\", COALESCE(m.alarm_msg, al.errorcode::TEXT) AS \"Message\", COALESCE(m.alarm_type, 'WARN') AS \"Severity\", COALESCE(m.alarm_detail, '') AS \"Details\"\nFROM public.ldi_alarm_log al\nLEFT JOIN public.ldi_alarm_ms_code m ON al.errorcode::TEXT = m.alarm_code::TEXT\nWHERE al.equipmentid = ${machine_id:singlequote}\n  AND al.logdate >= ((($__to + $__from)::BIGINT / 2)::BIGINT::TIMESTAMP) - INTERVAL '5 minutes'\n  AND al.logdate <= ((($__to + $__from)::BIGINT / 2)::BIGINT::TIMESTAMP) + INTERVAL '5 minutes'\nORDER BY al.logdate DESC",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Alarms within ±5 minutes of the clicked timestamp. Proves causality: data drift → alarm.",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Critical": {
                        "color": "#EF4444",
                        "text": "Critical"
                      },
                      "Warning": {
                        "color": "#FACC15",
                        "text": "Warning"
                      },
                      "WARN": {
                        "color": "#FACC15",
                        "text": "Warning"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Timestamp"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              },
              {
                "id": "decimals",
                "value": 6
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              },
              {
                "id": "decimals",
                "value": 6
              }
            ]
          }
        ]
      }
    },
