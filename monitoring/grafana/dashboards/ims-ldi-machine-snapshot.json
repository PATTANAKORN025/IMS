{
  "uid": "ldi-machine-snapshot",
  "title": "IMS LDI — Incident Snapshot",
  "description": "360° machine snapshot at the exact millisecond clicked from Process Timeline. Shows job context, physical variables, PE alignment, Cpk, and alarm proximity.",
  "tags": [
    "ims",
    "ldi",
    "snapshot",
    "rca",
    "drilldown"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT eqp_id AS __text, eqp_id AS __value FROM public.ldi_data ORDER BY eqp_id",
        "datasource": {
          "uid": "timescaledb"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "label": "Machine"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Machine Context",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "showHeader": true,
        "rowHeight": 0.8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT DISTINCT ON (d.eqp_id) d.eqp_id AS \"Machine\", d.state AS \"State\", d.mo AS \"MO\", d.fpn AS \"FPN\", d.layer_name AS \"Layer\", (d.board_no::TEXT || '/' || d.total_board::TEXT) AS \"Board\", d.filmno AS \"Film\", d.resist AS \"Resist\", d.scale_mode AS \"Scale Mode\", TO_CHAR(d.\"time\", 'YYYY-MM-DD HH24:MI:SS.MS') AS \"Timestamp\" FROM public.ldi_data d WHERE $__timeFilter(d.time) AND d.eqp_id IN (${machine_id:singlequote}) ORDER BY d.eqp_id, d.\"time\" DESC",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Exact machine state at the clicked timestamp. Shows job context (MO, FPN, Layer, Board).",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {
                        "color": "#22C55E",
                        "text": "RUNNING"
                      },
                      "false": {
                        "color": "#EF4444",
                        "text": "DOWN"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "temperature (°C)",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 4,
        "h": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#EF4444",
                "value": null
              },
              {
                "color": "#22C55E",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "text": {
          "valueSize": 28,
          "titleSize": 12
        },
        "noValue": "—"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT AVG(temperature)::NUMERIC AS value FROM public.ldi_data WHERE $__timeFilter(time) AND eqp_id IN (${machine_id:singlequote})",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "temperature at clicked moment"
    },
