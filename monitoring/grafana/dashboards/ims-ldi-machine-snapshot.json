    {
      "id": 8,
      "title": "Position Error (pe_1 ~ pe_6) + MAX|PE|",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 14,
        "h": 5
      },
      "options": {
        "showHeader": true,
        "rowHeight": 0.8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT ROUND(pe_1::NUMERIC, 3) AS \"pe_1\", ROUND(pe_2::NUMERIC, 3) AS \"pe_2\", ROUND(pe_3::NUMERIC, 3) AS \"pe_3\", ROUND(pe_4::NUMERIC, 3) AS \"pe_4\", ROUND(pe_5::NUMERIC, 3) AS \"pe_5\", ROUND(pe_6::NUMERIC, 3) AS \"pe_6\", ROUND(GREATEST(ABS(pe_1),ABS(pe_2),ABS(pe_3),ABS(pe_4),ABS(pe_5),ABS(pe_6))::NUMERIC, 3) AS \"MAX|PE|\", pe_setting AS \"PE Spec\"\nFROM public.ldi_data\nWHERE eqp_id = ${machine_id:singlequote}\n  AND $__timeFilter(time)\nORDER BY ABS(EXTRACT(EPOCH FROM time) - EXTRACT(EPOCH FROM ((($__to + $__from)::BIGINT / 2)::BIGINT::TIMESTAMP))) ASC\nLIMIT 1",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Individual PE values at the clicked moment. MAX|PE| = worst-case deviation across 6 fiducials.",
      "fieldConfig": {
        "defaults": {
          "unit": "lengthum",
          "decimals": 3
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "MAX|PE|"
