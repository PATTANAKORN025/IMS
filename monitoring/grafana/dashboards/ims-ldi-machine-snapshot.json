      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "timescaledb"
          },
          "rawSql": "SELECT \"time\" AS value\nFROM public.ldi_data\nWHERE eqp_id = ${machine_id:singlequote}\n  AND $__timeFilter(time)\nORDER BY ABS(EXTRACT(EPOCH FROM time) - EXTRACT(EPOCH FROM ((($__to + $__from)::BIGINT / 2)::BIGINT::TIMESTAMP))) ASC\nLIMIT 1",
          "format": "table"
        }
      ],
      "transparent": true,
      "description": "Precise raw timestamp from the database. Engineer can verify this matches the clicked point."
    },
