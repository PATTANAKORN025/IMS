            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, iface_name || ' (TX)' as metric, tx_mbps * -1 FROM public.net_metrics WHERE device_id IN (${machine_id:sqlstring}) AND $__timeFilter(time) ORDER BY time;",
          "format": "time_series"
        }
      ],
      "id": 9905,
