      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, cpu_load_percent FROM public.sys_metrics WHERE device_id IN (${machine_id:sqlstring}) AND $__timeFilter(time) ORDER BY time;",
