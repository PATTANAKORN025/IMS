{
  "id": null,
  "uid": "ims-v2-diagnostics",
  "title": "V2 System Health & Network Diagnostics",
  "tags": [
    "ims",
    "v2",
    "diagnostics",
    "auto-generated"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "graphTooltip": 1,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "machine_id",
        "type": "query",
        "query": "SELECT DISTINCT device_id FROM public.sys_metrics;",
        "datasource": {
          "type": "postgres",
          "uid": "timescaledb"
        },
        "refresh": 1,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "title": "V2 Architecture Verification",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "content": "# ✅ System V2 Diagnostics\nThis dashboard verifies the 3 core improvements of the Phase 1-3 architecture:\n1. **Null-Handling**: When a machine goes offline, metrics are skipped rather than logged as zero. You will see gaps instead of line drops.\n2. **Dynamic Network Interfaces**: Every active interface is captured dynamically. See the panels below.\n3. **Decentralized Parsing**: The new Node-RED parser architecture accurately captures CPU, Storage, and LDI stats concurrently.",
        "mode": "markdown"
      },
      "id": 9901
    },
    {
      "type": "timeseries",
      "title": "CPU Load (%) - Shows gap on offline",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "gradientMode": "opacity"
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, cpu_load_percent FROM public.sys_metrics WHERE device_id IN (${machine_id:sqlstring}) AND $__timeFilter(time) ORDER BY time;",
          "format": "time_series"
        }
      ],
      "id": 9902
    },
    {
      "type": "timeseries",
      "title": "RAM Usage (%)",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-BlPu"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "gradientMode": "opacity"
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, (ram_used_mb / NULLIF(ram_total_mb, 0)) * 100 AS \"RAM Used %\" FROM public.sys_metrics WHERE device_id IN (${machine_id:sqlstring}) AND $__timeFilter(time) ORDER BY time;",
          "format": "time_series"
        }
      ],
      "id": 9903
    },
    {
      "type": "row",
      "title": "Dynamic Network Interfaces Analysis",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 1
      },
      "id": 9904
    },
    {
      "type": "timeseries",
      "title": "Network Traffic (All Discovered Interfaces)",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "axisCenteredZero": true
          },
          "unit": "megabyte"
        }
      },
      "targets": [
        {
          "refId": "RX",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, iface_name || ' (RX)' as metric, rx_mbps FROM public.net_metrics WHERE device_id IN (${machine_id:sqlstring}) AND $__timeFilter(time) ORDER BY time;",
          "format": "time_series"
        },
        {
          "refId": "TX",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, iface_name || ' (TX)' as metric, tx_mbps * -1 FROM public.net_metrics WHERE device_id IN (${machine_id:sqlstring}) AND $__timeFilter(time) ORDER BY time;",
          "format": "time_series"
        }
      ],
      "id": 9905
    },
    {
      "type": "row",
      "title": "Storage Analysis",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 1
      },
      "id": 9906
    },
    {
      "type": "stat",
      "title": "Disk Free (GB)",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 12,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          },
          "unit": "decgbytes"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, disk_free_gb FROM public.sys_metrics WHERE device_id IN (${machine_id:sqlstring}) AND $__timeFilter(time) ORDER BY time DESC LIMIT 1;",
          "format": "table"
        }
      ],
      "id": 9907
    }
  ]
}