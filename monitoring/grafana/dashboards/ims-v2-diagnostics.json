        }
      ],
      "id": 9902,
      "description": "CPU load percentage over time. Shows gaps when machine is offline."
    },
    {
      "type": "timeseries",
      "title": "RAM Usage (%)",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-BlPu"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "gradientMode": "opacity"
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time, (ram_used_mb / NULLIF(ram_total_mb, 0)) * 100 AS \"RAM Used %\" FROM public.sys_metrics WHERE device_id IN (${machine_id:sqlstring}) AND $__timeFilter(time) ORDER BY time;",
          "format": "time_series"
        }
      ],
      "id": 9903,
      "description": "RAM utilization percentage calculated from used/total MB."
    },
