      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT 'Fleet Uptime' AS metric, CASE WHEN COUNT(*) FILTER (WHERE health_status = 'online') = COUNT(*) THEN 100.0 ELSE ROUND((COUNT(*) FILTER (WHERE health_status = 'online')::NUMERIC / NULLIF(COUNT(*), 0)) * 100, 2) END AS value FROM public.v_uptime_summary"
        }
      ]
    },
