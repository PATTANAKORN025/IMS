    {
      "id": 998,
      "title": "Fleet Summary (Hidden)",
      "type": "table",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 50
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT machine_id, ROUND(AVG(cpu_load_percent)::NUMERIC, 1) AS cpu, ROUND((AVG(ram_used_mb)/NULLIF(AVG(ram_total_mb),0)*100)::NUMERIC, 1) AS ram_pct, ROUND((AVG(disk_used_gb)/NULLIF(AVG(disk_total_gb),0)*100)::NUMERIC, 1) AS disk_pct, ROUND(AVG(temp_c)::NUMERIC, 0) AS temp, MAX(time) AS last_seen, COUNT(*) AS readings FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '5 minutes' GROUP BY machine_id ORDER BY cpu DESC"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "transparent": true
    },
