        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "unit": "percent"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT CASE WHEN (ldi_pe + ldi_je) > 0 THEN ROUND((100 - (ldi_pe + ldi_je) / 2)::NUMERIC, 1) ELSE 100 END AS value FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '5 minutes' AND machine_id = '${machine_id}' ORDER BY time DESC LIMIT 1"
        }
      ]
    },
    {
