    {
      "id": 1,
      "title": "Overall OEE",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 40
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "WITH latest AS (SELECT machine_id, ldi_throughput, ldi_uptime, ldi_pe, ldi_je, ldi_humidity FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '5 minutes' AND machine_id = '${machine_id}') SELECT CASE WHEN ldi_uptime > 0 THEN ROUND(((ldi_throughput / NULLIF(ldi_uptime, 0)) * (1 - (ldi_pe + ldi_je) / 200) * 100)::NUMERIC, 1) ELSE 0 END AS value FROM latest LIMIT 1"
        }
      ]
    },
    {
      "id": 2,
      "title": "Availability",
      "type": "gauge",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "unit": "percent"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT CASE WHEN ldi_uptime > 0 THEN ROUND((ldi_uptime / NULLIF(86400, 0) * 100)::NUMERIC, 1) ELSE 100 END AS value FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '5 minutes' AND machine_id = '${machine_id}' ORDER BY time DESC LIMIT 1"
        }
      ]
    },
