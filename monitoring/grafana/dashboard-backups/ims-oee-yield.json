        "unit": "percent"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "legendFormat": "PE (%)",
          "rawSql": "SELECT \"bucket\" AS \"time\", avg_ldi_pe AS \"PE (%)\" FROM public.telemetry_minute_summary WHERE $__timeFilter(\"bucket\") AND machine_id = '${machine_id}' AND avg_ldi_pe > 0 ORDER BY 1"
        },
        {
          "refId": "B",
          "format": "time_series",
          "legendFormat": "JE (%)",
          "rawSql": "SELECT \"bucket\" AS \"time\", avg_ldi_je AS \"JE (%)\" FROM public.telemetry_minute_summary WHERE $__timeFilter(\"bucket\") AND machine_id = '${machine_id}' AND avg_ldi_je > 0 ORDER BY 1"
        }
      ]
    },
