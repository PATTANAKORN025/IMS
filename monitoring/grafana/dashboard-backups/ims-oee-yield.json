    {
      "id": 10,
      "title": "Est. Daily Yield Loss (Baht)",
      "type": "stat",
      "datasource": {
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyTHB",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10000
              },
              {
                "color": "red",
                "value": 50000
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "unit": "currencyTHB"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "WITH daily AS (SELECT machine_id, AVG(ldi_pe) AS avg_pe, AVG(ldi_je) AS avg_je, AVG(ldi_throughput) AS avg_throughput, AVG(ldi_uptime) AS avg_uptime FROM public.machine_telemetry WHERE time > NOW() - INTERVAL '1 day' AND machine_id = '${machine_id}' GROUP BY machine_id) SELECT CASE WHEN avg_uptime > 0 THEN ROUND(((avg_pe + avg_je) / 200 * avg_throughput * 86400 * 250)::NUMERIC, 0) ELSE 0 END AS value FROM daily LIMIT 1"
        }
      ]
    },
    {
      "id": 11,
      "title": "PE & JE Trend (Defect Rate)",
