                    "placement": "bottom",
                    "calcs": [
                        "mean",
                        "max"
                    ]
                },
                "unit": "mbps"
            },
            "targets": [
                {
                    "refId": "A",
                    "format": "time_series",
                    "rawSql": "SELECT \"bucket\" AS \"time\", machine_id AS metric, avg_rx_mbps AS \"Download (Mbps)\" FROM public.telemetry_minute_summary WHERE $__timeFilter(\"bucket\") ORDER BY 1"
                },
                {
                    "refId": "B",
                    "format": "time_series",
                    "rawSql": "SELECT \"bucket\" AS \"time\", machine_id AS metric, (avg_tx_mbps * -1) AS \"Upload (Mbps)\" FROM public.telemetry_minute_summary WHERE $__timeFilter(\"bucket\") ORDER BY 1"
                }
            ]
        },
