        {
            "id": 1,
            "title": "CPU Load % (All Machines)",
            "type": "timeseries",
            "datasource": {
                "uid": "timescaledb"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 6
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "yellow",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 70
                            },
                            {
                                "color": "red",
                                "value": 90
                            }
                        ]
                    },
                    "custom": {
                        "fillOpacity": 15,
                        "lineWidth": 2,
                        "spanNulls": true,
                        "gradientMode": "scheme",
                        "thresholdsStyle": {
                            "mode": "line+area"
                        }
                    },
                    "color": {
                        "mode": "thresholds"
                    }
                }
            },
            "options": {
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                },
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": [
                        "mean",
                        "max",
                        "lastNotNull"
                    ]
                },
                "unit": "percent"
            },
            "targets": [
                {
                    "refId": "A",
                    "format": "time_series",
                    "rawSql": "SELECT time_bucket('1 minute', \"time\") AS \"time\", machine_id AS metric, AVG(cpu_load_percent) AS \"CPU Load %\" FROM public.machine_telemetry WHERE $__timeFilter(\"time\") GROUP BY 1, 2 ORDER BY 1;"
                }
            ]
        },
