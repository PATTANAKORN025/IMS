                                "value": 30
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Upload (Mbps)"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "fixedColor": "#5794F2",
                                    "mode": "fixed"
                                }
                            },
